#!/usr/bin/env python3
"""
Wrapper script to invoke HackIt's `vuln` group directly by calling main.py.
This avoids import/package resolution issues when executing the script directly.
Usage: python3 vuln sqli --url ...
"""
import sys
import subprocess
from pathlib import Path

ROOT = Path(__file__).resolve().parent
MAIN = ROOT / 'main.py'

if __name__ == '__main__':
    if not MAIN.exists():
        print('main.py not found in project root', file=sys.stderr)
        sys.exit(1)
    # Ensure we call the 'vuln' subgroup of the CLI
    args = [sys.executable, str(MAIN), 'vuln'] + sys.argv[1:]
    sys.exit(subprocess.call(args))
