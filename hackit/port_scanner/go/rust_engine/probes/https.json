[
  {
    "id": "https-get",
    "protocol": "tcp",
    "ports": [443, 8443, 9443],
    "payload_text": "GET / HTTP/1.0\r\nHost: localhost\r\n\r\n",
    "read_limit": 4096,
    "timeout_ms": 5000,
    "matchers": [
      {
        "kind": "contains",
        "pattern": "HTTP/",
        "weight": 10.0,
        "metadata": {"label": "https", "service": "HTTPS Server"}
      },
      {
        "kind": "contains",
        "pattern": "nginx",
        "weight": 8.0,
        "metadata": {"label": "nginx", "vendor": "nginx"}
      },
      {
        "kind": "contains",
        "pattern": "Apache",
        "weight": 8.0,
        "metadata": {"label": "apache", "vendor": "Apache"}
      },
      {
        "kind": "contains",
        "pattern": "Microsoft-IIS",
        "weight": 8.0,
        "metadata": {"label": "iis", "vendor": "Microsoft"}
      }
    ]
  },
  {
    "id": "tls-client-hello",
    "protocol": "tcp",
    "ports": [443, 8443, 993, 995, 465, 587],
    "payload_b64": "AAABAQ0GCSqGSIb3DQEHBwNCAQA=",
    "read_limit": 4096,
    "timeout_ms": 5000,
    "matchers": [
      {
        "kind": "prefix",
        "pattern": "\u0016\u0003",
        "weight": 10.0,
        "metadata": {"label": "tls", "protocol": "TLS"}
      }
    ]
  }
]
