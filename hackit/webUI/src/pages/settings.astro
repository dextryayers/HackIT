---
import Layout from '../layouts/Layout.astro';

const MODULE_CATEGORIES = {
  "dns_domain": { label: "DNS & Domain", icon: "fa-globe", color: "text-sky-400", desc: "DNS records, subdomains, whois", modules: ["crtsh", "dns_brute", "dns_deep_forensics", "dns_enum_full", "dns_resolver", "dnsdumpster", "dnshistory", "dnstwister", "domain_profile_deep", "rapiddns", "securitytrails", "subdomain_passive", "subdomain_takeover", "viewdns", "whois", "certificate_search", "certspotter", "hackertarget", "fullhunt"] },
  "web_server": { label: "Web & Server", icon: "fa-server", color: "text-emerald-400", desc: "HTTP headers, SSL, tech detection", modules: ["api_scanner", "builtwith", "crawler_core", "header_audit", "js_secrets", "secret_finder", "sensitive_files_hunter", "ssl_analyzer", "urlscan", "vulnerability_scanner_lite", "web_surface_mapper", "web_tech", "cloud_fingerprint_deep", "cve_exploit_lookup", "publicwww", "netlas", "fofa", "zoomeye", "binaryedge", "onyphe", "intelx", "leakix", "leakix_scanner", "censys", "firewall_detector", "javascript_deps_analyzer", "ssl_chain_analyzer", "http2_fingerprinter", "api_endpoint_fuzzer", "tracker_network_mapper", "open_redirect_scanner", "web_cookie_analyzer", "technology_stack_profiler", "cdn_origin_finder", "vulnerability_db_scanner"] },
  "email_osint": { label: "Email OSINT", icon: "fa-envelope", color: "text-cyan-400", desc: "Email harvest, SPF/DKIM/DMARC", modules: ["email_harvester", "email_security_deep", "email_verifier", "hunterhow", "breach_directory", "haveibeenpwned", "email_reputation_checker", "mail_server_analyzer", "rust_email_finder"] },
  "people_social": { label: "People & Social", icon: "fa-users", color: "text-purple-400", desc: "Social media, people search", modules: ["people_org_osint", "social_alias_hunter", "social_search", "tracker_identity_mapper", "whatsmyname_checker", "mobile_recon", "reverse_image_search"] },
  "cloud_infrastructure": { label: "Cloud & Infrastructure", icon: "fa-cloud", color: "text-orange-400", desc: "Cloud providers, CDN, ASN", modules: ["cloud_infrastructure_hunter", "cloud_probe", "cloud_recon", "asn_bgp_radar", "bgp_he_net", "robtex", "cloudflare_resolver"] },
  "threat_leaks": { label: "Threat & Leaks", icon: "fa-shield-halved", color: "text-red-400", desc: "Breach data, malware, VT", modules: ["abuseipdb", "breach_forensics", "darkweb_intel", "greynoise", "malware_reputation_radar", "otx", "pastebin_monitor", "shodan_full", "shodan", "threat_intel", "threatminer", "virustotal_full", "virustotal", "crypto_abuse_radar", "leak_checker_pro", "dark_web_scanner", "malware_sandbox_check", "phishing_detector"] },
  "historical_archive": { label: "Historical & Archive", icon: "fa-archive", color: "text-slate-400", desc: "Wayback, CDX, DNS history", modules: ["archive_forensics", "archive_url_miner", "archive", "wayback", "dork_engine", "git_leaks", "exposure_surface_deep", "google_dorks_deep"] },
  "geolocation_network": { label: "Geolocation & Network", icon: "fa-map-pin", color: "text-amber-400", desc: "IP geo, ports, topology", modules: ["geo_recon", "ip_geolocation", "network_topology_mapper", "port_scanner", "device_search", "financial_recon", "wigle"] }
};
---

<Layout title="HackIT OSINT | System Settings">
  <div class="max-w-6xl mx-auto p-8 space-y-6">
    <!-- Page Header -->
    <header class="flex justify-between items-start">
      <div>
        <h2 class="text-3xl font-bold text-sf-text tracking-tight flex items-center gap-3">
          <i class="fas fa-cog text-sf-tabActive"></i> System Settings
        </h2>
        <p class="text-sf-muted text-sm mt-1">Configure the HackIT OSINT intelligence engine. Settings are saved to your browser.</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="export-settings-btn" aria-label="Export all settings" class="px-4 py-2.5 bg-sf-card border border-sf-border text-sf-text text-xs font-bold rounded-lg hover:border-sf-muted transition-all uppercase tracking-widest flex items-center gap-2">
          <i class="fas fa-file-export"></i> Export
        </button>
        <label class="px-4 py-2.5 bg-sf-card border border-sf-border text-sf-text text-xs font-bold rounded-lg hover:border-sf-muted transition-all uppercase tracking-widest flex items-center gap-2 cursor-pointer">
          <i class="fas fa-file-import"></i> Import
          <input type="file" id="import-settings-input" accept=".json" class="hidden" aria-label="Import settings from file">
        </label>
        <a href="/intelligence" aria-label="Go to intelligence dashboard" class="px-5 py-2.5 bg-sf-tabActive text-black text-xs font-bold rounded-lg hover:bg-sky-400 transition-all uppercase tracking-widest flex items-center gap-2">
          <i class="fas fa-brain"></i> Intelligence
        </a>
      </div>
    </header>

    <!-- Settings Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- LEFT COLUMN (2/3) -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Scan Profile -->
        <div class="bg-sf-card border border-sf-border rounded-lg p-6">
          <h3 class="text-sm font-semibold text-sf-text mb-5 flex items-center gap-2"><i class="fas fa-sliders-h text-sf-tabActive"></i> Scan Profile</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            <label class="cursor-pointer" data-setting="depth" data-value="quick">
              <input type="radio" name="scan-depth" value="quick" class="hidden peer" aria-label="Quick scan depth">
              <div class="p-4 rounded-xl border border-sf-border bg-sf-lightbg peer-checked:border-sf-tabActive peer-checked:bg-sf-tabActive/5 transition-all text-center">
                <i class="fas fa-bolt text-lg text-yellow-500 mb-1"></i>
                <div class="text-xs font-bold text-sf-text">Quick</div>
                <div class="text-[9px] text-sf-muted mt-0.5">~2 min</div>
              </div>
            </label>
            <label class="cursor-pointer" data-setting="depth" data-value="normal">
              <input type="radio" name="scan-depth" value="normal" class="hidden peer" aria-label="Normal scan depth">
              <div class="p-4 rounded-xl border border-sf-border bg-sf-lightbg peer-checked:border-sf-tabActive peer-checked:bg-sf-tabActive/5 transition-all text-center">
                <i class="fas fa-gauge text-lg text-emerald-500 mb-1"></i>
                <div class="text-xs font-bold text-sf-text">Normal</div>
                <div class="text-[9px] text-sf-muted mt-0.5">~5 min</div>
              </div>
            </label>
            <label class="cursor-pointer" data-setting="depth" data-value="deep">
              <input type="radio" name="scan-depth" value="deep" class="hidden peer" checked aria-label="Deep scan depth">
              <div class="p-4 rounded-xl border border-sf-border bg-sf-lightbg peer-checked:border-sf-tabActive peer-checked:bg-sf-tabActive/5 transition-all text-center">
                <i class="fas fa-water text-lg text-blue-500 mb-1"></i>
                <div class="text-xs font-bold text-sf-text">Deep</div>
                <div class="text-[9px] text-sf-muted mt-0.5">~15 min</div>
              </div>
            </label>
            <label class="cursor-pointer" data-setting="depth" data-value="exhaustive">
              <input type="radio" name="scan-depth" value="exhaustive" class="hidden peer" aria-label="Exhaustive scan depth">
              <div class="p-4 rounded-xl border border-sf-border bg-sf-lightbg peer-checked:border-sf-tabActive peer-checked:bg-sf-tabActive/5 transition-all text-center">
                <i class="fas fa-infinity text-lg text-purple-500 mb-1"></i>
                <div class="text-xs font-bold text-sf-text">Exhaustive</div>
                <div class="text-[9px] text-sf-muted mt-0.5">~30+ min</div>
              </div>
            </label>
          </div>
          <div class="flex items-center gap-4 p-3 rounded-lg bg-sf-lightbg border border-sf-border mb-3">
            <i class="fas fa-bullseye text-sf-tabActive"></i>
            <div class="flex-1">
              <div class="text-xs text-sf-text font-medium">Sniper Ratio</div>
              <div class="text-[10px] text-sf-muted">Concurrency & resource profile</div>
            </div>
            <select id="setting-sniper-ratio" aria-label="Sniper ratio" class="bg-sf-card border border-sf-border text-xs text-sf-text rounded-lg px-3 py-2 focus:outline-none focus:border-sf-tabActive">
              <option value="stealth">Stealth (30 threads)</option>
              <option value="balanced">Balanced (150 threads)</option>
              <option value="max" selected>MAX POWER (300 threads)</option>
            </select>
          </div>
          <div class="flex items-center gap-4 p-3 rounded-lg bg-sf-lightbg border border-sf-border">
            <i class="fas fa-clock text-sf-muted"></i>
            <div class="flex-1">
              <div class="text-xs text-sf-text font-medium">Module Timeout</div>
              <div class="text-[10px] text-sf-muted">Seconds per module before timeout</div>
            </div>
            <select id="setting-timeout" aria-label="Module timeout" class="bg-sf-card border border-sf-border text-xs text-sf-text rounded-lg px-3 py-2 focus:outline-none focus:border-sf-tabActive">
              <option value="5">5s</option>
              <option value="10">10s</option>
              <option value="15" selected>15s</option>
              <option value="30">30s</option>
              <option value="60">60s</option>
            </select>
          </div>
        </div>

        <!-- Module Selection -->
        <div class="bg-sf-card border border-sf-border rounded-lg p-6">
          <h3 class="text-sm font-semibold text-sf-text mb-5 flex items-center gap-2"><i class="fas fa-puzzle-piece text-sf-tabActive"></i> Module Selection</h3>
          <div class="space-y-3" id="module-categories">
            {Object.entries(MODULE_CATEGORIES).map(([key, cat]) => (
              <div class="module-category border border-sf-border rounded-lg overflow-hidden">
                <div class="flex items-center justify-between p-3 bg-sf-lightbg cursor-pointer category-header" data-category={key}>
                  <div class="flex items-center gap-3">
                    <i class={`fas ${cat.icon} ${cat.color} w-4`}></i>
                    <div>
                      <div class="text-xs font-medium text-sf-text">{cat.label}</div>
                      <div class="text-[9px] text-sf-muted">{cat.desc} &mdash; {cat.modules.length} modules</div>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <label class="flex items-center gap-1.5 text-[10px] text-sf-muted cursor-pointer" onclick="event.stopPropagation()">
                      <input type="checkbox" class="category-toggle accent-sf-tabActive" data-category={key} checked onchange="toggleCategory(event)" aria-label={`Toggle ${cat.label} category`}>
                      <span>{cat.modules.length} modules</span>
                    </label>
                    <i class="fas fa-chevron-down text-sf-muted text-[10px] transition-transform category-chevron"></i>
                  </div>
                </div>
                <div class="module-list hidden border-t border-sf-border">
                  <div class="grid grid-cols-2 md:grid-cols-3 gap-1 p-3">
                    {cat.modules.map(mod => (
                      <label class="flex items-center gap-2 px-2 py-1.5 rounded hover:bg-sf-card cursor-pointer text-[11px]">
                        <input type="checkbox" class="module-toggle accent-sf-tabActive" data-category={key} data-module={mod} checked>
                        <span class="text-sf-text font-mono">{mod}</span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="flex gap-3 mt-4">
            <button id="select-all-modules" aria-label="Select all modules" class="text-[10px] bg-sf-lightbg border border-sf-border hover:border-sf-muted px-3 py-1.5 rounded text-sf-text transition-all font-medium">Select All</button>
            <button id="deselect-all-modules" aria-label="Deselect all modules" class="text-[10px] bg-sf-lightbg border border-sf-border hover:border-sf-muted px-3 py-1.5 rounded text-sf-text transition-all font-medium">Deselect All</button>
          </div>
        </div>

        <!-- API Keys & Integrations -->
        <div class="bg-sf-card border border-sf-border rounded-lg p-6">
          <h3 class="text-sm font-semibold text-sf-text mb-5 flex items-center gap-2"><i class="fas fa-key text-sf-tabActive"></i> API Keys & Integrations</h3>
          <p class="text-[10px] text-sf-muted mb-4">Keys are sent to the backend server on save. Modules will use these keys automatically.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-shield text-red-400 text-[10px]"></i> Shodan
              </label>
              <input type="password" id="api-shodan" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="shodan API key" spellcheck="false" aria-label="Shodan API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-bug text-emerald-400 text-[10px]"></i> VirusTotal
              </label>
              <input type="password" id="api-virustotal" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="virustotal API key" spellcheck="false" aria-label="VirusTotal API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-eye text-sky-400 text-[10px]"></i> SecurityTrails
              </label>
              <input type="password" id="api-securitytrails" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="securitytrails API key" spellcheck="false" aria-label="SecurityTrails API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-database text-cyan-400 text-[10px]"></i> AbuseIPDB
              </label>
              <input type="password" id="api-abuseipdb" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="abuseipdb API key" spellcheck="false" aria-label="AbuseIPDB API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-network-wired text-orange-400 text-[10px]"></i> BinaryEdge
              </label>
              <input type="password" id="api-binaryedge" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="binaryedge API key" spellcheck="false" aria-label="BinaryEdge API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-search text-purple-400 text-[10px]"></i> GreyNoise
              </label>
              <input type="password" id="api-greynoise" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="greynoise API key" spellcheck="false" aria-label="GreyNoise API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-bolt text-yellow-400 text-[10px]"></i> Hunter.io
              </label>
              <input type="password" id="api-hunter" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="hunter.io API key" spellcheck="false" aria-label="Hunter.io API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-database text-cyan-400 text-[10px]"></i> Have I Been Pwned
              </label>
              <input type="password" id="api-haveibeenpwned" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="hibp API key" spellcheck="false" aria-label="Have I Been Pwned API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-envelope text-pink-400 text-[10px]"></i> EmailRep
              </label>
              <input type="password" id="api-email_rep" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="emailrep.io API key" spellcheck="false" aria-label="EmailRep API key">
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium flex items-center gap-2 mb-1">
                <i class="fas fa-shield-halved text-lime-400 text-[10px]"></i> LeakCheck
              </label>
              <input type="password" id="api-leakcheck" class="api-key-input w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="leak-check.net API key" spellcheck="false" aria-label="LeakCheck API key">
            </div>
          </div>
          <div class="flex gap-2 mt-4">
            <button id="save-api-keys" aria-label="Save API keys to server" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-bold px-4 py-2 rounded-lg transition-all flex items-center gap-1.5">
              <i class="fas fa-cloud-upload-alt"></i> Save Keys to Server
            </button>
            <button id="load-api-keys" aria-label="Load API keys from server" class="bg-sf-border hover:bg-sf-muted/20 text-sf-text text-[10px] font-medium px-4 py-2 rounded-lg transition-all flex items-center gap-1.5">
              <i class="fas fa-cloud-download-alt"></i> Load from Server
            </button>
          </div>
          <p id="api-key-status" class="text-[9px] text-sf-muted mt-2 hidden"></p>
        </div>

        <!-- Network & Proxy -->
        <div class="bg-sf-card border border-sf-border rounded-lg p-6">
          <h3 class="text-sm font-semibold text-sf-text mb-5 flex items-center gap-2"><i class="fas fa-globe text-sf-tabActive"></i> Network & Proxy</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium mb-1 flex items-center gap-2">
                <i class="fas fa-shield-halved text-yellow-400 text-[10px]"></i> HTTP/HTTPS Proxy
              </label>
              <input type="text" id="setting-proxy-http" class="w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="http://proxy.example.com:8080" spellcheck="false" aria-label="HTTP/HTTPS proxy URL">
              <p class="text-[9px] text-sf-muted mt-1">Leave empty for direct connection</p>
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium mb-1 flex items-center gap-2">
                <i class="fas fa-socks text-blue-400 text-[10px]"></i> SOCKS5 Proxy
              </label>
              <input type="text" id="setting-proxy-socks" class="w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="socks5://127.0.0.1:9050" spellcheck="false" aria-label="SOCKS5 proxy URL">
              <p class="text-[9px] text-sf-muted mt-1">SOCKS proxy overrides HTTP proxy</p>
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium mb-1 flex items-center gap-2">
                <i class="fas fa-server text-slate-400 text-[10px]"></i> Custom DNS Resolver
              </label>
              <input type="text" id="setting-dns-resolver" class="w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="8.8.8.8" spellcheck="false" aria-label="Custom DNS resolver">
              <p class="text-[9px] text-sf-muted mt-1">Default: system DNS</p>
            </div>
            <div class="p-3 rounded-lg bg-sf-lightbg border border-sf-border">
              <label class="text-[11px] text-sf-text font-medium mb-1 flex items-center gap-2">
                <i class="fas fa-user-secret text-sf-text text-[10px]"></i> Custom User-Agent
              </label>
              <input type="text" id="setting-user-agent" class="w-full bg-sf-card border border-sf-border rounded px-3 py-1.5 text-xs text-sf-text focus:outline-none focus:border-sf-tabActive font-mono" placeholder="Mozilla/5.0 (X11; Linux x86_64) ..." spellcheck="false" aria-label="Custom user agent">
              <p class="text-[9px] text-sf-muted mt-1">Browser user agent for HTTP requests</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN (1/3) -->
      <div class="space-y-6">

        <!-- Stealth & Evasion -->
        <div class="bg-sf-card border border-sf-border rounded-lg p-6">
          <h3 class="text-sm font-semibold text-sf-text mb-5 flex items-center gap-2"><i class="fas fa-shield text-sf-tabActive"></i> Stealth & Evasion</h3>
          <div class="space-y-4">
            <label class="flex items-center justify-between cursor-pointer">
              <div><div class="text-xs font-medium text-sf-text">Stealth Mode</div><div class="text-[9px] text-sf-muted">Avoid intrusive probes</div></div>
              <div class="relative w-9 h-5" data-setting="stealth_mode" onclick="toggleSwitch(this)" role="switch" aria-label="Stealth mode toggle" tabindex="0">
                <div class="w-9 h-5 bg-sf-border rounded-full transition-colors"><div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white/20 rounded-full transition-all"></div></div>
              </div>
            </label>
            <label class="flex items-center justify-between cursor-pointer">
              <div><div class="text-xs font-medium text-sf-text">Verify Findings</div><div class="text-[9px] text-sf-muted">Resolve & verify DNS</div></div>
              <div class="relative w-9 h-5 bg-sf-green rounded-full" data-setting="verify_findings" onclick="toggleSwitch(this)" role="switch" aria-label="Verify findings toggle" tabindex="0">
                <div class="absolute right-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-all"></div>
              </div>
            </label>
            <label class="flex items-center justify-between cursor-pointer">
              <div><div class="text-xs font-medium text-sf-text">Passive Only</div><div class="text-[9px] text-sf-muted">No direct connections</div></div>
              <div class="relative w-9 h-5 bg-sf-border rounded-full" data-setting="passive_only" onclick="toggleSwitch(this)" role="switch" aria-label="Passive only toggle" tabindex="0">
