---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HackIt | Secure Login">
	<main class="min-h-screen flex items-center justify-center p-4 relative overflow-hidden">
		<!-- Background Gradients -->
		<div class="absolute top-0 left-0 w-full h-full opacity-20 pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-cyan-500 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-magenta-500 rounded-full blur-[120px]"></div>
		</div>

		<div id="login-card" class="w-full max-w-md bg-white/5 backdrop-blur-xl border border-white/10 p-8 rounded-2xl shadow-2xl relative z-10 opacity-0 transform translate-y-10">
			<div class="text-center mb-8">
				<h1 class="text-4xl font-bold tracking-tighter mb-2">
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600">HACKIT</span>
					<span class="text-white/40">v2.1</span>
				</h1>
				<p class="text-white/60 text-sm">AUTHORIZED ACCESS ONLY</p>
			</div>

			<form id="login-form" class="space-y-6">
				<div class="space-y-2">
					<label class="text-xs uppercase tracking-widest text-cyan-400 font-bold">User Identity</label>
					<input 
						type="text" 
						id="username" 
						required 
						class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors"
						placeholder="ENTER USERNAME"
					/>
				</div>

				<div class="space-y-2">
					<label class="text-xs uppercase tracking-widest text-cyan-400 font-bold">Encrypted Key</label>
					<input 
						type="password" 
						id="password" 
						required 
						class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors"
						placeholder="••••••••"
					/>
				</div>

				<button 
					type="submit"
					class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-bold py-3 rounded-lg shadow-lg shadow-cyan-500/20 transform hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
				>
					INITIALIZE SESSION
				</button>
			</form>

			<div id="error-msg" class="mt-4 text-center text-red-500 text-xs font-bold hidden uppercase tracking-tighter">
				[!] AUTHENTICATION FAILED: ACCESS DENIED
			</div>
		</div>
	</main>

	<script is:inline>
		// GSAP Intro
		window.addEventListener('load', () => {
			gsap.to("#login-card", {
				opacity: 1,
				y: 0,
				duration: 1,
				ease: "expo.out"
			});
		});

		document.getElementById('login-form').addEventListener('submit', (e) => {
			e.preventDefault();
			const u = document.getElementById('username').value;
			const p = document.getElementById('password').value;
			const err = document.getElementById('error-msg');

			if (u === 'hackit' && p === 'admin123') {
				// Successful login - use localStorage for session simulation
				localStorage.setItem('hackit_session', 'active');
				gsap.to("#login-card", {
					opacity: 0,
					scale: 0.9,
					duration: 0.5,
					onComplete: () => {
						window.location.href = '/';
					}
				});
			} else {
				err.classList.remove('hidden');
				gsap.fromTo("#login-card", { x: -10 }, { x: 10, duration: 0.1, repeat: 5, yoyo: true });
			}
		});
	</script>
</Layout>
