---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HackIT OSINT | Intelligence Dashboard">
	<!-- Mission History View (Visible when no target) -->
	<div id="history-view" class="hidden p-8 space-y-6">
		<header class="flex justify-between items-center mb-10">
			<div class="space-y-1">
				<h2 class="text-3xl font-bold text-sf-text tracking-tight">Mission History</h2>
				<p class="text-sf-muted text-sm">Review past and active intelligence gathering missions.</p>
			</div>
			<a href="/" aria-label="Start new mission" class="bg-sf-text text-sf-lightbg px-6 py-2.5 rounded-md text-sm font-bold hover:bg-white transition-all">New Mission</a>
		</header>

		<div class="bg-sf-card border border-sf-border rounded-xl overflow-hidden shadow-2xl">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-sf-lightbg/50 border-b border-sf-border">
						<th class="px-6 py-4 text-[10px] font-bold text-sf-muted uppercase tracking-widest">Mission Target</th>
						<th class="px-6 py-4 text-[10px] font-bold text-sf-muted uppercase tracking-widest">Status</th>
						<th class="px-6 py-4 text-[10px] font-bold text-sf-muted uppercase tracking-widest">Intelligence</th>
						<th class="px-6 py-4 text-[10px] font-bold text-sf-muted uppercase tracking-widest">Duration</th>
						<th class="px-6 py-4 text-[10px] font-bold text-sf-muted uppercase tracking-widest">Action</th>
					</tr>
				</thead>
				<tbody id="history-tbody" class="divide-y divide-sf-border/50">
					<!-- Dynamically Populated -->
				</tbody>
			</table>
			<div id="history-empty" class="p-20 text-center space-y-4 hidden">
				<i class="fas fa-history text-sf-muted/20 text-5xl"></i>
				<p class="text-sf-muted font-mono text-xs uppercase tracking-widest">No previous missions found in database.</p>
			</div>
		</div>
	</div>

	<!-- Active Intelligence Dashboard -->
	<div id="active-dashboard" class="hidden">
	<!-- Loading Skeleton -->
	<div id="loading-skeleton" class="p-8 space-y-6">
		<div class="animate-pulse space-y-6">
			<div class="h-8 bg-sf-card rounded w-1/3"></div>
			<div class="grid grid-cols-4 gap-6">
				<div class="h-32 bg-sf-card rounded-lg"></div>
				<div class="h-32 bg-sf-card rounded-lg"></div>
				<div class="h-32 bg-sf-card rounded-lg"></div>
				<div class="h-32 bg-sf-card rounded-lg"></div>
			</div>
		</div>
	</div>
	<!-- Page Header & Tab Navigation (Sticky Container) -->
	<div class="sticky top-16 z-30 bg-sf-lightbg">
		<!-- Page Header -->
		<div class="border-b border-sf-border px-8 py-5 flex items-center justify-between">
			<div class="space-y-1">
				<div class="flex items-center gap-3">
					<h2 id="header-target" class="text-xl font-semibold text-sf-text">Target Name</h2>
					<span id="header-status" class="bg-sf-green/10 text-sf-green text-[10px] px-2.5 py-1 rounded-sm font-medium uppercase tracking-wider border border-sf-green/20">Running Mission</span>
				</div>
				<p id="header-subtitle" class="text-sf-muted text-xs flex items-center gap-2">
					HackIT Intelligence Gathering in Progress...
				</p>
			</div>
			<div class="flex items-center gap-6">
				<div class="flex flex-col items-end">
					<span class="text-[10px] text-sf-muted uppercase font-medium tracking-wider">Duration</span>
					<span class="font-mono text-sm text-sf-text" id="scan-duration">00:00:00</span>
				</div>
				<div class="h-8 w-px bg-sf-border"></div>
				<button id="btn-export-hackit" aria-label="Export intelligence report" class="bg-sf-text hover:bg-white text-sf-lightbg px-4 py-2 rounded-md text-xs font-semibold flex items-center gap-2 transition-all">
					<i class="fas fa-file-export"></i> Export Intelligence
				</button>
			</div>
		</div>

		<!-- Tab Navigation -->
		<div class="border-b border-sf-border px-8 flex justify-between items-center relative">
		<nav class="flex gap-6 pt-3" id="tab-nav">
			<button class="pb-3 text-sm font-medium border-b-2 border-sf-text text-sf-text transition-all flex items-center gap-2" data-target="tab-overview" aria-label="Overview tab">
				Overview
			</button>
			<button class="pb-3 text-sm font-medium border-b-2 border-transparent text-sf-muted hover:text-sf-text transition-all flex items-center gap-2" data-target="tab-browse" aria-label="Browse findings tab">
				Browse
			</button>
			<button class="pb-3 text-sm font-medium border-b-2 border-transparent text-sf-muted hover:text-sf-text transition-all flex items-center gap-2" data-target="tab-graph" aria-label="Graph visualization tab">
				Graph
			</button>
			<button onclick="window.location.href='/log?target=' + new URLSearchParams(window.location.search).get('target')" aria-label="View mission logs" class="pb-3 text-sm font-medium border-b-2 border-transparent text-sf-muted hover:text-sf-text transition-all flex items-center gap-2">
				Log
			</button>
		</nav>
		<div class="flex gap-3">
			<button class="text-sf-muted hover:text-sf-text transition-all mb-3" aria-label="Refresh data">
				<i class="fas fa-sync-alt text-xs"></i>
			</button>
		</div>
	</div>

	<!-- Main Content Area -->
	<div class="p-8">
		
		<!-- TAB: OVERVIEW -->
		<div id="tab-overview" class="tab-content space-y-6 block">
			<!-- Empty State -->
			<div id="overview-empty" class="hidden p-16 text-center space-y-4">
				<i class="fas fa-search text-sf-muted/20 text-5xl"></i>
				<p class="text-sf-muted font-mono text-xs uppercase tracking-widest">No findings discovered for this target yet.</p>
				<p class="text-sf-muted text-[10px]">Data will populate as the scan progresses.</p>
			</div>
			<!-- Metrics & Mini Charts Row -->
			<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
				<div class="bg-sf-card border border-sf-border rounded-lg p-6 relative overflow-hidden">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-6">Threat Metrics</h3>
					<div class="space-y-4">
						<div class="flex justify-between items-end border-b border-sf-border pb-3">
							<div class="space-y-1">
								<span class="text-[11px] text-sf-muted font-medium">Total Findings</span>
								<p class="text-2xl font-semibold text-sf-text" id="overview-total-count">0</p>
							</div>
						</div>
						<div class="flex justify-between items-end border-b border-sf-border pb-3">
							<div class="space-y-1">
								<span class="text-[11px] text-sf-muted font-medium">High Risk</span>
								<p class="text-2xl font-semibold text-red-500" id="overview-risk-count">0</p>
							</div>
						</div>
						<div class="flex justify-between items-end border-b border-sf-border pb-3">
							<div class="space-y-1">
								<span class="text-[11px] text-sf-muted font-medium">Data Sources</span>
								<p class="text-2xl font-semibold text-sf-text" id="overview-sources-count">0</p>
							</div>
						</div>
						<div class="flex justify-between items-end">
							<div class="space-y-1">
								<span class="text-[11px] text-sf-muted font-medium">Categories</span>
								<p class="text-2xl font-semibold text-sf-text" id="overview-categories-count">0</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Radar Chart -->
				<div class="bg-sf-card border border-sf-border rounded-lg p-6 flex flex-col md:col-span-1">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-4">Infiltration Vectors</h3>
					<div class="flex-1 relative w-full flex justify-center items-center min-h-[200px]">
						<canvas id="radarChart"></canvas>
					</div>
				</div>

				<!-- Risk Doughnut -->
				<div class="bg-sf-card border border-sf-border rounded-lg p-6 flex flex-col md:col-span-1">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-4">Risk Distribution</h3>
					<div class="flex-1 relative w-full flex justify-center items-center min-h-[200px]">
						<canvas id="doughnutChart"></canvas>
					</div>
				</div>

				<!-- Source Distribution -->
				<div class="bg-sf-card border border-sf-border rounded-lg p-6 flex flex-col md:col-span-1">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-4">Top Sources</h3>
					<div class="flex-1 relative w-full min-h-[200px]">
						<canvas id="sourceChart"></canvas>
					</div>
				</div>
			</div>

			<!-- Charts Row 2 -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="bg-sf-card border border-sf-border rounded-lg p-6">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-6">Evidence per Sector</h3>
					<div class="w-full h-72 relative">
						<canvas id="barChart"></canvas>
					</div>
				</div>
				<div class="bg-sf-card border border-sf-border rounded-lg p-6">
					<h3 class="text-xs font-semibold text-sf-muted uppercase tracking-wider mb-6">Findings Timeline</h3>
					<div class="w-full h-72 relative">
						<canvas id="timelineChart"></canvas>
					</div>
				</div>
			</div>
		</div>

		<!-- TAB: BROWSE -->
		<div id="tab-browse" class="tab-content hidden h-[calc(100vh-280px)] flex flex-col">
			<div id="browse-summary-container" class="flex-1 overflow-auto bg-sf-card border border-sf-border rounded-lg">
				<table class="w-full text-left text-sm border-collapse">
					<thead class="bg-sf-card sticky top-0 z-10 border-b border-sf-border">
						<tr>
							<th class="px-6 py-4 font-semibold text-sf-muted uppercase tracking-wider text-[11px]">Intelligence Type</th>
							<th class="px-6 py-4 font-semibold text-sf-muted uppercase tracking-wider text-[11px]">Sector Category</th>
							<th class="px-6 py-4 font-semibold text-sf-muted uppercase tracking-wider text-[11px] text-center">Unique</th>
							<th class="px-6 py-4 font-semibold text-sf-muted uppercase tracking-wider text-[11px] text-center">Total</th>
							<th class="px-6 py-4 font-semibold text-sf-muted uppercase tracking-wider text-[11px]">Latest Asset</th>
						</tr>
					</thead>
					<tbody id="browse-summary-tbody" class="divide-y divide-sf-border">
						<!-- Rows injected by script -->
					</tbody>
				</table>
			</div>

			<!-- Detail View -->
			<div id="browse-detail-container" class="hidden flex-1 flex flex-col bg-sf-card border border-sf-border rounded-lg overflow-hidden">
				<div class="p-4 bg-sf-card border-b border-sf-border flex justify-between items-center">
					<div class="flex items-center gap-4">
						<button id="browse-back-btn" aria-label="Back to browse summary" class="flex items-center gap-2 text-sf-text hover:text-white font-medium text-sm transition-colors">
							<i class="fas fa-chevron-left text-xs"></i> Back
						</button>
						<span id="browse-detail-type" class="px-3 py-1 bg-sf-lightbg text-sf-text rounded-md text-[11px] font-medium border border-sf-border uppercase"></span>
					</div>
					<div class="relative">
						<i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-sf-muted text-xs"></i>
						<input type="text" id="browse-detail-search" placeholder="Search..." aria-label="Search findings" class="pl-8 pr-4 py-1.5 text-xs border border-sf-border rounded-md bg-sf-lightbg w-64 text-sf-text focus:outline-none focus:border-sf-muted transition-all">
					</div>
				</div>
				<div class="flex-1 overflow-auto">
					<table class="w-full text-left text-sm border-collapse">
						<thead class="bg-sf-card sticky top-0 z-10 border-b border-sf-border">
							<tr>
								<th class="px-6 py-3 font-semibold text-sf-muted uppercase text-[11px] tracking-wider">Digital Asset / Entity</th>
								<th class="px-6 py-3 font-semibold text-sf-muted uppercase text-[11px] tracking-wider">Source Provider</th>
								<th class="px-6 py-3 font-semibold text-sf-muted uppercase text-[11px] tracking-wider">Security Status</th>
								<th class="px-6 py-3 font-semibold text-sf-muted uppercase text-[11px] tracking-wider">Technical Resolution</th>
							</tr>
						</thead>
						<tbody id="browse-detail-tbody" class="divide-y divide-sf-border">
							<!-- Detail rows injected -->
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<!-- TAB: GRAPH -->
		<div id="tab-graph" class="tab-content hidden h-[calc(100vh-280px)]">
			<div class="bg-sf-lightbg border border-sf-border rounded-lg w-full h-full relative overflow-hidden">
				<div class="absolute top-4 right-4 z-10 flex gap-2">
					<button id="graph-pause" aria-label="Pause graph simulation" class="bg-sf-card border border-sf-border hover:bg-sf-border p-2 rounded-md text-sf-text transition-all text-xs">
						<i class="fas fa-pause"></i>
					</button>
					<button id="graph-recenter" aria-label="Recenter graph view" class="bg-sf-card border border-sf-border hover:bg-sf-border p-2 rounded-md text-sf-text transition-all text-xs">
						<i class="fas fa-expand-arrows-alt"></i>
					</button>
				</div>
				<div id="network-container" class="w-full h-full"></div>
				<div id="graph-loading" class="absolute inset-0 bg-sf-lightbg/90 flex flex-col items-center justify-center z-20">
					<div class="w-8 h-8 border-2 border-sf-text border-t-transparent rounded-full animate-spin mb-4"></div>
					<p class="text-xs font-medium text-sf-muted uppercase tracking-wider">Synthesizing Topology Graph...</p>
				</div>
			</div>
		</div>

		<div id="tab-raw" class="tab-content hidden">
			<div class="bg-sf-lightbg text-green-500 p-6 rounded-lg font-mono text-[11px] overflow-auto h-[calc(100vh-280px)] border border-sf-border">
				<div class="flex justify-between items-center mb-4 border-b border-sf-border pb-3">
					<span class="font-medium text-sf-text tracking-wider uppercase">Raw JSON Stream</span>
					<button class="text-[10px] bg-sf-card border border-sf-border hover:bg-sf-border px-3 py-1.5 rounded-md text-sf-text transition-all font-medium" id="copy-raw" aria-label="Copy raw JSON stream">Copy Stream</button>
				</div>
				<pre id="raw-json-display" class="whitespace-pre-wrap break-all leading-relaxed">System standby...</pre>
			</div>
		</div>

		<!-- TAB: MISSION LOGS (The requested "Log" tab) -->
		<div id="tab-logs" class="tab-content hidden">
			<div class="bg-[#050505] border border-sf-border rounded-lg overflow-hidden flex flex-col h-[calc(100vh-280px)] shadow-2xl">
				<div class="bg-sf-card border-b border-sf-border px-4 py-2 flex items-center justify-between">
					<div class="flex items-center gap-3">
						<span class="text-[10px] font-mono text-sf-muted uppercase tracking-widest">Titan Engine Telemetry Stream</span>
						<a href="#" id="view-full-log" class="text-[9px] bg-sf-text text-sf-lightbg px-2 py-0.5 rounded font-bold hover:bg-white transition-colors">VIEW FULL PAGE LOG</a>
					</div>
					<div id="log-status-tab" class="text-[10px] font-mono text-sf-muted uppercase tracking-widest flex items-center gap-2">
						<div class="w-1.5 h-1.5 rounded-full bg-sf-green animate-pulse"></div> Link Active
					</div>
				</div>
				<div id="terminal-body-tab" class="flex-1 p-6 font-mono text-[11px] overflow-auto leading-relaxed scroll-smooth">
					<div class="space-y-1" id="log-container-tab">
						<div class="text-sf-muted">[SYSTEM] INITIALIZING TELEMETRY LINK...</div>
					</div>
				</div>
				<div class="bg-sf-card border-t border-sf-border px-4 py-2 flex justify-between items-center text-[9px] font-mono text-sf-muted uppercase tracking-widest">
					<div id="log-count-tab">LOGS: 0</div>
				</div>
			</div>
		</div>

	</div>

	<!-- Error Overlay -->
	<div id="error-overlay" class="fixed inset-0 bg-black/80 z-[100] hidden items-center justify-center">
		<div class="bg-sf-card rounded-xl p-8 max-w-md w-full border border-red-500/30">
			<div class="w-12 h-12 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4 text-red-500 text-xl">
				<i class="fas fa-exclamation-triangle"></i>
			</div>
			<h3 class="text-lg font-semibold text-sf-text text-center mb-2">Command Center Link Lost</h3>
			<p class="text-sf-muted text-sm text-center mb-6">The Titan Engine on port 8080 is unresponsive. Re-establish connection through the secure tunnel.</p>
			<div class="bg-sf-lightbg p-4 rounded-md border border-sf-border font-mono text-xs text-sf-muted mb-6 space-y-1">
				<p>> cd d:\web\hacks\hackstools\hackit\webUI</p>
				<p>> ./run_engine.bat</p>
			</div>
			<button onclick="window.location.reload()" class="w-full bg-sf-text hover:bg-white text-sf-lightbg py-2.5 rounded-md font-semibold transition-all">Re-Engage Engine</button>
		</div>
	</div>

	</div><!-- End active-dashboard -->

	<script is:inline>
		// Tab Switching Logic
		document.querySelectorAll('[data-target]').forEach(btn => {
			btn.addEventListener('click', () => {
				const target = btn.getAttribute('data-target');
				if(!target) return;
				
				document.querySelectorAll('[data-target]').forEach(b => {
					b.classList.remove('border-sf-text', 'text-sf-text');
					b.classList.add('border-transparent', 'text-sf-muted');
				});
				btn.classList.remove('border-transparent', 'text-sf-muted');
				btn.classList.add('border-sf-text', 'text-sf-text');
				
				document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
				document.getElementById(target).classList.remove('hidden');
			});
		});

		function renderLogs(logs) {
			const logBody = document.getElementById('log-table-body');
			if(!logBody) return;
			logBody.innerHTML = '';
			[...logs].reverse().forEach(log => {
				const tr = document.createElement('tr');
				const statusColor = log.status === 'Success' ? 'text-emerald-400' : 'text-rose-500';
				tr.innerHTML = `
					<td class="px-6 py-4 font-mono text-sf-muted">${log.time}</td>
					<td class="px-6 py-4 font-bold text-white">${log.module}</td>
					<td class="px-6 py-4 ${statusColor} font-bold tracking-widest text-[10px] uppercase">${log.status}</td>
					<td class="px-6 py-4 text-sf-muted">${log.found ? log.found + ' items' : log.error || '-'}</td>
				`;
				logBody.appendChild(tr);
			});
		}

		let networkInstance = null;
		let chartInstances = {};
		let latestFindings = [];
		let currentSummary = [];

		async function requestScan(url) {
			try {
				const res = await fetch(url);
				if (!res.ok) throw new Error(`HTTP Error: ${res.status} ${res.statusText}`);
				return await res.json();
			} catch (err) {
				console.error("Scan Request Failed:", url, err);
				throw err;
			}
		}

		let seconds = 0;
		setInterval(() => {
			seconds++;
			const h = Math.floor(seconds / 3600).toString().padStart(2, '0');
			const m = Math.floor((seconds % 3600) / 60).toString().padStart(2, '0');
			const s = (seconds % 60).toString().padStart(2, '0');
			document.getElementById('scan-duration').innerText = `${h}:${m}:${s}`;
		}, 1000);

		function destroyChart(key) {
			if (chartInstances[key]) {
				chartInstances[key].destroy();
				delete chartInstances[key];
			}
		}

		function chartColor(i) {
			const palette = ['#38BDF8','#F59E0B','#10B981','#EF4444','#8B5CF6','#EC4899','#14B8A6','#F97316','#6366F1','#84CC16','#06B6D4','#D946EF','#0EA5E9','#EAB308','#22C55E'];
			return palette[i % palette.length];
		}

		function renderCharts(stats) {
			if (!stats) return;
			const riskDist = stats.risk_distribution || {};
			const typeDist = stats.type_distribution || {};
			const sourceDist = stats.source_distribution || {};
			const catDist = stats.category_distribution || {};
			const timeline = stats.timeline || [];
			const isDark = document.documentElement.classList.contains('dark') || !document.documentElement.classList.contains('light');
			const textColor = isDark ? '#888888' : '#64748b';
			const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
			const accent = '#38BDF8';

			// ── Radar: 4 threat axes ──
			destroyChart('radar');
			const radarEl = document.getElementById('radarChart');
			if (radarEl) {
				const rLabels = ['High Risk', 'Elevated Risk', 'Standard Target', 'Informational'];
				const rData = [riskDist['High Risk']||0, riskDist['Elevated Risk']||0, riskDist['Standard Target']||0, riskDist['Informational']||0];
				chartInstances.radar = new Chart(radarEl.getContext('2d'), {
					type: 'radar',
					data: {
						labels: rLabels,
						datasets: [{
							label: 'Findings',
							data: rData,
							backgroundColor: 'rgba(56, 189, 248, 0.15)',
							borderColor: accent,
							pointBackgroundColor: accent,
							pointBorderColor: '#fff',
							pointHoverBackgroundColor: '#fff',
							pointHoverBorderColor: accent,
							borderWidth: 2
						}]
					},
					options: {
						responsive: true, maintainAspectRatio: false,
						scales: { r: {
							beginAtZero: true,
							ticks: { display: false, stepSize: 1 },
							grid: { color: gridColor },
							angleLines: { color: gridColor },
							pointLabels: { color: textColor, font: { size: 9, weight: 'bold', family: 'Inter' } }
						}},
						plugins: { legend: { display: false } }
					}
				});
			}

			// ── Doughnut: risk distribution ──
			destroyChart('doughnut');
			const doughEl = document.getElementById('doughnutChart');
			if (doughEl) {
				const dLabels = Object.keys(riskDist).filter(k => riskDist[k] > 0);
				const dData = dLabels.map(k => riskDist[k]);
				const dColors = ['#EF4444','#F59E0B','#3B82F6','#6B7280'];
				if (dLabels.length === 0) { dLabels.push('No Data'); dData.push(1); dColors.push('#333'); }
				chartInstances.doughnut = new Chart(doughEl.getContext('2d'), {
					type: 'doughnut',
					data: {
						labels: dLabels,
						datasets: [{
							data: dData,
							backgroundColor: dColors.slice(0, dData.length),
							borderWidth: 1,
							borderColor: isDark ? '#1a1a2e' : '#fff'
						}]
					},
					options: {
						responsive: true, maintainAspectRatio: false,
						plugins: {
							legend: { position: 'bottom', labels: { color: textColor, font: { size: 9 }, boxWidth: 10, padding: 8 } }
						},
						cutout: '60%'
					}
				});
			}

			// ── Source (horizontal bar): top 8 sources ──
			destroyChart('source');
			const srcEl = document.getElementById('sourceChart');
			if (srcEl) {
				let srcEntries = Object.entries(sourceDist).sort((a,b) => b[1]-a[1]).slice(0, 8);
				if (srcEntries.length === 0) srcEntries = [['No Data', 1]];
				const srcLabels = srcEntries.map(e => e[0].length > 18 ? e[0].slice(0,16)+'…' : e[0]);
				const srcData = srcEntries.map(e => e[1]);
				chartInstances.source = new Chart(srcEl.getContext('2d'), {
					type: 'bar',
					data: {
						labels: srcLabels,
						datasets: [{ data: srcData, backgroundColor: srcData.map((_,i) => chartColor(i)), borderRadius: 3 }]
					},
					options: {
						indexAxis: 'y', responsive: true, maintainAspectRatio: false,
						plugins: { legend: { display: false } },
						scales: {
							x: { display: false, grid: { display: false } },
							y: { grid: { display: false }, ticks: { color: textColor, font: { size: 9 } } }
						}
					}
				});
			}

			// ── Bar: type distribution, top 15 ──
			destroyChart('bar');
			const barEl = document.getElementById('barChart');
			if (barEl) {
				let typeEntries = Object.entries(typeDist).sort((a,b) => b[1]-a[1]).slice(0, 15);
				if (typeEntries.length === 0) typeEntries = [['No Data', 0]];
				const barLabels = typeEntries.map(e => e[0].length > 20 ? e[0].slice(0,18)+'…' : e[0]);
				const barData = typeEntries.map(e => e[1]);
				chartInstances.bar = new Chart(barEl.getContext('2d'), {
					type: 'bar',
					data: { labels: barLabels, datasets: [{ data: barData, backgroundColor: accent, borderRadius: 4, barPercentage: 0.6 }] },
					options: {
						responsive: true, maintainAspectRatio: false,
						plugins: { legend: { display: false } },
						scales: {
							y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor, font: { size: 9 } } },
							x: { grid: { display: false }, ticks: { maxRotation: 45, color: textColor, font: { size: 8 } } }
						}
					}
				});
			}

			// ── Timeline line chart ──
			destroyChart('timeline');
			const tlEl = document.getElementById('timelineChart');
			if (tlEl && timeline.length > 0) {
				const tlLabels = timeline.map(t => t.module ? (t.module.length > 12 ? t.module.slice(0,10)+'…' : t.module) : t.time || '');
				const tlData = timeline.map(t => t.count || 0);
				chartInstances.timeline = new Chart(tlEl.getContext('2d'), {
					type: 'line',
					data: {
						labels: tlLabels,
						datasets: [{
							label: 'Findings Accumulated',
							data: tlData,
							borderColor: accent,
							backgroundColor: 'rgba(56, 189, 248, 0.1)',
							fill: true,
							tension: 0.3,
							pointBackgroundColor: accent,
							pointRadius: 3,
							pointHoverRadius: 5,
							borderWidth: 2
						}]
					},
					options: {
						responsive: true, maintainAspectRatio: false,
						plugins: {
							legend: { labels: { color: textColor, font: { size: 9 }, boxWidth: 12 } }
						},
						scales: {
							y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor, font: { size: 9 } } },
							x: { grid: { display: false }, ticks: { maxRotation: 45, color: textColor, font: { size: 7 } } }
						},
						interaction: { intersect: false, mode: 'index' }
					}
				});
			} else if (tlEl) {
				chartInstances.timeline = new Chart(tlEl.getContext('2d'), {
					type: 'line',
					data: { labels: ['Start','End'], datasets: [{ data: [0,0], borderColor: accent, borderWidth: 1 }] },
					options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
				});
			}
		}

		function renderGraph(target, findings) {
			const container = document.getElementById('network-container');
			const nodes = new vis.DataSet([
				{ 
					id: 0, 
					label: target, 
					shape: 'circularImage', 
					image: 'https://cdn-icons-png.flaticon.com/512/3208/3208727.png', // Main Master Server
					size: 50,
					font: { color: 'var(--color-text-primary)', size: 14, face: 'Inter', strokeWidth: 4, strokeColor: 'var(--color-bg-primary)' }
				}
			]);
			const edges = new vis.DataSet([]);

			let nodeId = 1;
			findings.forEach((f, idx) => {
				if(idx > 150) return;
				
				let icon = 'https://cdn-icons-png.flaticon.com/512/7747/7747592.png'; // Default Subdomain/Web
				let size = 15;
				
				if (f.type.toLowerCase().includes('mail') || f.type.toLowerCase().includes('email')) {
					icon = 'https://cdn-icons-png.flaticon.com/512/18234/18234236.png'; // Mail Server
					size = 18;
				} else if (f.type.toLowerCase().includes('cloud') || f.category.toLowerCase().includes('infrastructure')) {
					icon = 'https://cdn-icons-png.flaticon.com/512/2318/2318786.png'; // Cloud Server
					size = 18;
				} else if (f.type.toLowerCase().includes('database') || f.type.toLowerCase().includes('storage')) {
					icon = 'https://cdn-icons-png.flaticon.com/512/2906/2906206.png'; // Database Storage
					size = 18;
				}

				let color = '#444444';
				if(f.threat_level && f.threat_level.includes('High')) {
					color = '#ef4444';
					size = 22; // Make critical nodes bigger
				}

				nodes.add({ 
					id: nodeId, 
					label: f.entity.substring(0, 20), 
					title: `<b>Type:</b> ${f.type}<br><b>Source:</b> ${f.source}`, 
					shape: 'circularImage',
					image: icon,
					size: size,
					borderWidth: 2,
					color: { border: color, background: 'var(--color-bg-primary)' },
					font: { color: 'var(--color-text-muted)', size: 9, face: 'Inter' }
				});

				edges.add({ from: 0, to: nodeId, color: { color: 'var(--color-border)', opacity: 0.2 }, width: 1 });
				nodeId++;
			});

			const options = {
				physics: { enabled: true, barnesHut: { gravitationalConstant: -10000, springLength: 200 } },
				interaction: { hover: true, tooltipDelay: 150 },
				nodes: { borderWidth: 2, shadow: { enabled: true, color: 'rgba(0,0,0,0.5)', size: 3 } }
			};
			document.getElementById('graph-loading').classList.add('hidden');
			if (networkInstance) networkInstance.destroy();
			networkInstance = new vis.Network(container, { nodes, edges }, options);
		}

		document.addEventListener('DOMContentLoaded', async () => {
			const urlParams = new URLSearchParams(window.location.search);
			const target = urlParams.get('target');
			
			const historyView = document.getElementById('history-view');
			const activeDashboard = document.getElementById('active-dashboard');

			if (!target) {
				historyView.classList.remove('hidden');
				activeDashboard.classList.add('hidden');
				loadHistory();
			} else {
				historyView.classList.add('hidden');
				activeDashboard.classList.remove('hidden');
				document.getElementById('header-target').innerText = target;
				initDashboard(target);
			}

			async function loadHistory() {
				const tbody = document.getElementById('history-tbody');
				const empty = document.getElementById('history-empty');
				try {
					const res = await fetch('/api/jobs');
					const jobs = await res.json();
					if (jobs.length === 0) {
						empty.classList.remove('hidden');
						return;
					}
					tbody.innerHTML = jobs.map(job => `
						<tr class="hover:bg-sf-card transition-all group">
							<td class="px-6 py-4 font-semibold text-sf-text">${job.target}</td>
							<td class="px-6 py-4">
								<span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-widest ${job.status === 'Completed' ? 'bg-sf-green/10 text-sf-green border border-sf-green/20' : 'bg-sf-tabActive/10 text-sf-tabActive border border-sf-tabActive/20 animate-pulse'}">
									${job.status}
								</span>
							</td>
							<td class="px-6 py-4 text-sf-muted text-xs font-mono">${job.findings ? job.findings.length : 0} findings</td>
							<td class="px-6 py-4 text-sf-muted text-xs font-mono">${job.duration || 'N/A'}</td>
							<td class="px-6 py-4 text-right">
								<a href="/intelligence?target=${job.target}" class="text-[10px] font-bold text-sf-tabActive hover:text-white transition-all uppercase tracking-widest bg-sf-tabActive/5 px-3 py-1 rounded border border-sf-tabActive/20">Open Intelligence</a>
							</td>
						</tr>
					`).join('');
				} catch (err) { console.error(err); }
			}

			async function initDashboard(targetName) {
				// Hide loading skeleton once dashboard is ready
				const skeleton = document.getElementById('loading-skeleton');
				if (skeleton) skeleton.classList.add('hidden');
				try {
					// Check for existing job first
					const existingRes = await fetch(`/api/job-by-target?target=${encodeURIComponent(targetName)}`);
					const existingJob = await existingRes.json();
					if (existingJob && existingJob.job_id) {
						if (existingJob.status === 'Completed' || existingJob.status === 'Error') {
							processResults(existingJob, targetName);
							return;
						} else if (existingJob.status === 'Running') {
							startPolling('/api/status', existingJob.job_id, targetName);
							return;
						}
					}

					// No existing job — start new scan
					const savedSettings = localStorage.getItem('hackit_scan_settings');
					let url = `/api/scan?target=${encodeURIComponent(targetName)}`;
					if (savedSettings) {
						try {
							const s = JSON.parse(savedSettings);
							url += `&depth=${encodeURIComponent(s.depth || 'deep')}`;
							url += `&sniper_ratio=${encodeURIComponent(s.sniperRatio || 'max')}`;
							url += `&timeout=${encodeURIComponent(s.timeout || 15)}`;
							url += `&verbose=${encodeURIComponent(s.verbose ?? 1)}`;
							url += `&max_findings=${encodeURIComponent(s.maxFindings || 5000)}`;
							url += `&format=${encodeURIComponent(s.exportFormat || 'json')}`;
							if (s.modules) {
								const activeModules = Object.entries(s.modules).filter(([,v]) => v).map(([k]) => k).join(',');
								if (activeModules) url += `&modules=${encodeURIComponent(activeModules)}`;
							}
							if (s.toggles) {
								Object.entries(s.toggles).forEach(([k, v]) => {
									url += `&${encodeURIComponent(k)}=${v ? '1' : '0'}`;
								});
							}
							if (s.apiKeys && Object.keys(s.apiKeys).length > 0) {
								url += `&api_keys=${encodeURIComponent(JSON.stringify(s.apiKeys))}`;
							}
							if (s.proxy) {
								if (s.proxy.http) url += `&proxy_http=${encodeURIComponent(s.proxy.http)}`;
								if (s.proxy.socks) url += `&proxy_socks=${encodeURIComponent(s.proxy.socks)}`;
							}
							if (s.network) {
								if (s.network.dnsResolver) url += `&dns_resolver=${encodeURIComponent(s.network.dnsResolver)}`;
								if (s.network.userAgent) url += `&user_agent=${encodeURIComponent(s.network.userAgent)}`;
							}
							if (s.automation?.webhookUrl) {
								url += `&webhook_url=${encodeURIComponent(s.automation.webhookUrl)}`;
							}
							if (s.moduleToggles && Object.keys(s.moduleToggles).length > 0) {
								url += `&module_toggles=${encodeURIComponent(JSON.stringify(s.moduleToggles))}`;
							}
							if (s.performance) {
								url += `&concurrency=${encodeURIComponent(s.performance.concurrency || 50)}`;
								url += `&brute_depth=${encodeURIComponent(s.performance.bruteDepth || 500)}`;
								url += `&port_range=${encodeURIComponent(s.performance.portRange || 1000)}`;
							}
						} catch(e) {}
					}
					const res = await fetch(url);
					const data = await res.json();
					if (data.job_id) {
						startPolling('/api/status', data.job_id, targetName);
					}
				} catch (err) { console.error(err); }
			}

			function startPolling(statusUrl, id, targetName) {
				let pollingInterval = setInterval(async () => {
					try {
						const res = await fetch(`${statusUrl}?job_id=${id}`);
						const job = await res.json();
						
						document.getElementById('raw-json-display').innerText = JSON.stringify(job, null, 4);
						if (job.live_logs) renderLiveLogs(job.live_logs);

						if (job.findings && job.findings.length > 0) {
							document.getElementById('overview-total-count').innerText = job.findings.length;
						}
						if (job.summary && job.summary.length > 0) {
							const prevSummary = currentSummary;
							currentSummary = job.summary;
							if (JSON.stringify(prevSummary) !== JSON.stringify(currentSummary)) {
								renderBrowseSummary(currentSummary);
							}
						}
						if (job.stats) {
							const prevFindings = latestFindings.length;
							latestFindings = job.findings || [];
							if (prevFindings !== latestFindings.length && latestFindings.length > 0) {
								renderGraph(targetName, latestFindings);
							}
						}

						if (job.status === 'Completed' || job.status === 'Error') {
							clearInterval(pollingInterval);
							processResults(job, targetName);
						} else if (job.duration) {
							document.getElementById('scan-duration').innerText = job.duration;
						}
					} catch (e) { console.error(e); }
				}, 1000);
			}

			function processResults(data, targetName) {
				const emptyOverview = document.getElementById('overview-empty');
				if (data && data.findings && data.findings.length > 0) {
					if (emptyOverview) emptyOverview.classList.add('hidden');
				} else if (emptyOverview) {
					emptyOverview.classList.remove('hidden');
				}
				if (data && data.findings) {
					latestFindings = data.findings;
					currentSummary = data.summary || [];

					Object.values(chartInstances).forEach(c => { try { c.destroy(); } catch(e) {} });
					chartInstances = {};

					renderBrowseSummary(currentSummary);
					renderGraph(targetName, latestFindings);

					if (data.stats) {
						renderCharts(data.stats);
						document.getElementById('overview-total-count').innerText = latestFindings.length;
						document.getElementById('overview-risk-count').innerText = data.stats.risk_distribution['High Risk'] || 0;
						const srcCount = Object.keys(data.stats.source_distribution || {}).length;
						document.getElementById('overview-sources-count').innerText = srcCount || '0';
						const catCount = Object.keys(data.stats.category_distribution || {}).length;
						document.getElementById('overview-categories-count').innerText = catCount || '0';
					}
					document.getElementById('header-status').innerText = 'MISSION COMPLETE';
					document.getElementById('header-status').className = 'px-2.5 py-1 bg-sf-green/10 text-sf-green rounded-sm text-[10px] font-medium border border-sf-green/20 tracking-wider uppercase';
					document.getElementById('header-subtitle').innerHTML = 'HackIT Intelligence Gathering Completed...';
				}
			}

			const navLogLink = document.getElementById('nav-log-link');
			if (navLogLink) navLogLink.href = `/log?target=${encodeURIComponent(target)}`;
			document.getElementById('view-full-log').onclick = (e) => {
				e.preventDefault();
				window.location.href = `/log?target=${encodeURIComponent(target)}`;
			};

			document.getElementById('btn-export-hackit').onclick = () => {
				const rawData = document.getElementById('raw-json-display').innerText;
				const blob = new Blob([rawData], { type: 'application/json' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = `hackit_intel_${target}_${new Date().getTime()}.json`;
				a.click();
			};
		});

		let processedLogsSet = new Set();
		function renderLiveLogs(logs) {
			const container = document.getElementById('log-container-tab');
			const body = document.getElementById('terminal-body-tab');
			const countEl = document.getElementById('log-count-tab');
			
			logs.forEach(msg => {
				if (!processedLogsSet.has(msg)) {
					const div = document.createElement('div');
					if (msg.includes('[+]')) div.className = 'text-emerald-400';
					else if (msg.includes('[!]')) div.className = 'text-red-400';
					else if (msg.includes('[INFO]')) div.className = 'text-sf-tabActive';
					else div.className = 'text-sf-text opacity-90';
					
					div.innerText = msg;
					container.appendChild(div);
					processedLogsSet.add(msg);
					body.scrollTop = body.scrollHeight;
				}
			});
			countEl.innerText = `LOGS: ${processedLogsSet.size}`;
		}

		function renderBrowseSummary(summary) {
			const tbody = document.getElementById('browse-summary-tbody');
			if(!tbody) return;
			tbody.innerHTML = '';
			
			summary.forEach(item => {
				const tr = document.createElement('tr');
				tr.className = 'hover:bg-sf-lightbg cursor-pointer transition-colors border-l-2 border-l-transparent hover:border-l-sf-text';
				tr.innerHTML = `
					<td class="px-6 py-4 text-sf-text font-medium">${item.type}</td>
					<td class="px-6 py-4 text-sf-muted text-[11px] uppercase tracking-wider">${item.category || 'UNCLASSIFIED'}</td>
					<td class="px-6 py-4 text-sf-text font-mono text-center text-sm">${item.unique_count}</td>
					<td class="px-6 py-4 text-sf-muted font-mono text-center text-xs">${item.total_count}</td>
					<td class="px-6 py-4 text-sf-muted text-xs truncate max-w-xs">${item.last_finding || '-'}</td>
				`;
				tr.onclick = () => showBrowseDetail(item.type);
				tbody.appendChild(tr);
			});
		}

		function renderDetailTable(findings) {
			const tbody = document.getElementById('browse-detail-tbody');
			tbody.innerHTML = '';
			findings.forEach(f => {
				const tr = document.createElement('tr');
				const isHigh = f.threat_level === 'High Risk';
				tr.className = `hover:bg-sf-lightbg transition-colors ${isHigh ? 'bg-red-500/5' : ''}`;
				const tagsHtml = (f.tags || []).map(t => `<span class="inline-block px-1.5 py-0.5 bg-sf-lightbg border border-sf-border rounded text-[8px] uppercase tracking-wider text-sf-muted mr-1">${t}</span>`).join('');
				tr.innerHTML = `
					<td class="px-6 py-3 font-mono text-xs ${isHigh ? 'text-red-400' : 'text-sf-text'}">
						<div class="flex items-center gap-2">
							${isHigh ? '<i class="fas fa-biohazard"></i>' : ''}
							${f.entity}
						</div>
						<div class="mt-1 flex flex-wrap gap-1">${tagsHtml}</div>
					</td>
					<td class="px-6 py-3 text-sf-muted text-xs">${f.source}</td>
					<td class="px-6 py-3">
						<span class="text-[10px] font-medium tracking-wider uppercase ${f.status === 'Live' || f.status === 'Breached' ? 'text-emerald-500' : 'text-sf-muted'}">
							${f.status || 'UNVERIFIED'}
						</span>
						<div class="text-[9px] text-sf-muted mt-0.5">${f.confidence || ''} ${f.threat_level !== 'Informational' ? '· ' + f.threat_level : ''}</div>
					</td>
					<td class="px-6 py-3 font-mono text-[10px] text-sf-muted truncate max-w-sm" title="${f.resolution || ''}">${f.resolution || '-'}</td>
				`;
				tbody.appendChild(tr);
			});
		}

		function showBrowseDetail(type) {
			const filtered = latestFindings.filter(f => f.type === type);
			document.getElementById('browse-summary-container').classList.add('hidden');
			document.getElementById('browse-detail-container').classList.remove('hidden');
			document.getElementById('browse-detail-type').innerText = type;
			renderDetailTable(filtered);
		}

		document.getElementById('browse-back-btn').onclick = () => {
			document.getElementById('browse-detail-container').classList.add('hidden');
			document.getElementById('browse-summary-container').classList.remove('hidden');
		};



		document.getElementById('browse-detail-search').oninput = (e) => {
			const term = e.target.value.toLowerCase();
			const type = document.getElementById('browse-detail-type').innerText;
			const filtered = latestFindings.filter(f => f.type === type && (f.entity.toLowerCase().includes(term) || f.source.toLowerCase().includes(term)));
			renderDetailTable(filtered);
		};

		document.getElementById('copy-raw').onclick = () => {
			const content = document.getElementById('raw-json-display').innerText;
			navigator.clipboard.writeText(content).then(() => {
				const btn = document.getElementById('copy-raw');
				btn.innerText = 'Copied Successfully!';
				setTimeout(() => btn.innerText = 'Copy Stream Buffer', 2000);
			});
		};

		document.getElementById('btn-export-titan').onclick = () => {
			const rawData = document.getElementById('raw-json-display').innerText;
			const blob = new Blob([rawData], { type: 'application/json' });
			const url = URL.createObjectURL(blob);
			const a = document.createElement('a');
			a.href = url;
			a.download = `titan_intel_report_${new Date().getTime()}.json`;
			a.click();
		};

		/* ─── Settings Management ─── */
		function toggleSwitch(el) {
			const track = el.querySelector('div');
			if (!track) return;
			const thumb = track.querySelector('div');
			const isOn = track.classList.contains('bg-sf-green');
			if (isOn) {
				track.classList.remove('bg-sf-green');
				thumb.classList.remove('right-0.5', 'bg-white');
				track.classList.add('bg-sf-border');
				thumb.classList.add('left-0.5', 'bg-white/20');
			} else {
				track.classList.remove('bg-sf-border');
				thumb.classList.remove('left-0.5', 'bg-white/20');
				track.classList.add('bg-sf-green');
				thumb.classList.add('right-0.5', 'bg-white');
			}
		}

		function getSettings() {
			const settings = {
				depth: document.querySelector('input[name="scan-depth"]:checked')?.value || 'deep',
				sniperRatio: document.getElementById('setting-sniper-ratio')?.value || 'max',
				timeout: parseInt(document.getElementById('setting-timeout')?.value || '15'),
				verbose: parseInt(document.getElementById('setting-verbose')?.value || '1'),
				maxFindings: parseInt(document.getElementById('setting-max-findings')?.value || '5000'),
				exportFormat: document.querySelector('input[name="export-format"]:checked')?.value || 'json',
				modules: {},
				toggles: {}
			};
			document.querySelectorAll('.module-toggle').forEach(cb => {
				const parent = cb.closest('.setting-module');
				const label = parent?.querySelector('.text-xs.font-medium')?.innerText.trim().toLowerCase().replace(/[^a-z0-9]+/g, '_');
				if (label) settings.modules[label] = cb.checked;
			});
			document.querySelectorAll('#tab-settings [data-setting]').forEach(el => {
				const track = el.querySelector('div');
				const isOn = track?.classList.contains('bg-sf-green');
				const name = el.getAttribute('data-setting');
				if (name) settings.toggles[name] = !!isOn;
			});
			return settings;
		}

		function applySettings(settings) {
			if (!settings) return;
			const depthInput = document.querySelector(`input[name="scan-depth"][value="${settings.depth || 'deep'}"]`);
			if (depthInput) depthInput.checked = true;
			const sniperEl = document.getElementById('setting-sniper-ratio');
			if (sniperEl) sniperEl.value = settings.sniperRatio || 'max';
			const timeoutEl = document.getElementById('setting-timeout');
			if (timeoutEl) timeoutEl.value = settings.timeout || '15';
			const verboseEl = document.getElementById('setting-verbose');
			if (verboseEl) verboseEl.value = settings.verbose ?? '1';
			const maxFindingsEl = document.getElementById('setting-max-findings');
			if (maxFindingsEl) maxFindingsEl.value = String(settings.maxFindings || '5000');
			const exportInput = document.querySelector(`input[name="export-format"][value="${settings.exportFormat || 'json'}"]`);
			if (exportInput) exportInput.checked = true;
			if (settings.modules) {
				Object.entries(settings.modules).forEach(([name, val]) => {
					document.querySelectorAll('.module-toggle').forEach(c => {
						const parent = c.closest('.setting-module');
						const label = parent?.querySelector('.text-xs.font-medium')?.innerText.trim().toLowerCase().replace(/[^a-z0-9]+/g, '_');
						if (label === name) c.checked = val;
					});
				});
			}
			if (settings.toggles) {
				Object.entries(settings.toggles).forEach(([name, val]) => {
					const el = document.querySelector(`#tab-settings [data-setting="${name}"]`);
					if (el) {
						const track = el.querySelector('div');
						const thumb = track?.querySelector('div');
						if (track && thumb) {
							if (val) {
								track.classList.remove('bg-sf-border');
								thumb.classList.remove('left-0.5', 'bg-white/20');
								track.classList.add('bg-sf-green');
								thumb.classList.add('right-0.5', 'bg-white');
							} else {
								track.classList.remove('bg-sf-green');
								thumb.classList.remove('right-0.5', 'bg-white');
								track.classList.add('bg-sf-border');
								thumb.classList.add('left-0.5', 'bg-white/20');
							}
						}
					}
				});
			}
		}

		function saveSettingsToStorage() {
			const settings = getSettings();
			localStorage.setItem('hackit_scan_settings', JSON.stringify(settings));
			const btn = document.getElementById('save-settings');
			if (btn) {
				const orig = btn.innerHTML;
				btn.innerHTML = '<i class="fas fa-check-circle"></i> Saved!';
				btn.classList.add('bg-emerald-500');
				setTimeout(() => {
					btn.innerHTML = orig;
					btn.classList.remove('bg-emerald-500');
				}, 1500);
			}
		}

		function resetSettingsToDefault() {
			localStorage.removeItem('hackit_scan_settings');
			document.querySelector('input[name="scan-depth"][value="deep"]').checked = true;
			document.getElementById('setting-sniper-ratio').value = 'max';
			document.getElementById('setting-timeout').value = '15';
			document.getElementById('setting-verbose').value = '1';
			document.getElementById('setting-max-findings').value = '5000';
			document.querySelector('input[name="export-format"][value="json"]').checked = true;
			document.querySelectorAll('.module-toggle').forEach(c => c.checked = true);
			document.querySelectorAll('#tab-settings [data-setting]').forEach(el => {
				const track = el.querySelector('div');
				const thumb = track?.querySelector('div');
				if (track && thumb) {
					track.classList.remove('bg-sf-green');
					track.classList.add('bg-sf-border');
					thumb.classList.remove('right-0.5', 'bg-white');
					thumb.classList.add('left-0.5', 'bg-white/20');
				}
			});
			const btn = document.getElementById('reset-settings');
			if (btn) {
				const orig = btn.innerHTML;
				btn.innerHTML = '<i class="fas fa-check"></i> Defaults Restored';
				setTimeout(() => btn.innerHTML = orig, 1500);
			}
		}

		document.addEventListener('DOMContentLoaded', () => {
			const saved = localStorage.getItem('hackit_scan_settings');
			if (saved) {
				try { applySettings(JSON.parse(saved)); } catch(e) {}
			}

			document.getElementById('save-settings')?.addEventListener('click', saveSettingsToStorage);
			document.getElementById('reset-settings')?.addEventListener('click', resetSettingsToDefault);

			document.querySelectorAll('.module-toggle').forEach(cb => {
				cb.addEventListener('change', () => {
					document.getElementById('save-settings') && (document.getElementById('save-settings').innerHTML = '<i class="fas fa-check"></i> Save Settings');
				});
			});
		});
	</script>
</div>
</Layout>
