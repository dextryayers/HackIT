---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="HackIt | SQLi Automated Penetration Engine">
  <div class="p-8 lg:p-12">
    <!-- Header -->
    <div class="mb-10 flex justify-between items-center">
      <div>
        <h2 class="text-3xl font-black tracking-tighter text-red-500 uppercase flex items-center gap-3">
          <span class="bg-red-500 text-black px-2 py-1 rounded shadow-[0_0_15px_rgba(239,68,68,0.5)]">AUTO</span>
          SQLi Penetration Engine
        </h2>
        <p class="text-white/40 text-xs mt-2 uppercase tracking-[0.2em] font-medium">
          Autonomous Data Exfiltration & Schema Orchestration
        </p>
      </div>
      <div id="status-badge" class="hidden">
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/30 px-6 py-2 rounded-full shadow-lg shadow-red-500/10">
          <div class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_10px_#ef4444]"></div>
          <span class="text-[11px] font-black text-red-500 uppercase tracking-widest">PENETRATION_ACTIVE</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Sidebar Controls -->
      <div class="lg:col-span-3 space-y-6">
        <div class="bg-dark-800/80 backdrop-blur-xl border border-white/10 p-8 rounded-3xl shadow-2xl relative overflow-hidden group">
          <div class="relative space-y-6">
            <h3 class="text-xs font-black text-white/40 tracking-widest uppercase mb-4">Tactical Config</h3>
            
            <div>
              <label class="text-[10px] text-red-500 font-black block mb-2 uppercase tracking-widest">Attack Target</label>
              <input type="text" id="target-url" placeholder="http://example.com/page.php?id=1" class="w-full bg-black/60 border border-white/10 rounded-xl px-5 py-3 text-sm focus:border-red-500 outline-none text-white transition-all placeholder:text-white/10" />
            </div>

            <div>
              <label class="text-[10px] text-red-500 font-black block mb-2 uppercase tracking-widest">Exfiltration Mode</label>
              <select class="w-full bg-black/60 border border-white/10 rounded-xl px-5 py-3 text-sm focus:border-red-500 outline-none text-white transition-all">
                <option>AUTO-DUMP (Full Schema)</option>
                <option>SCHEMA ONLY</option>
                <option>SAMPLE DATA (Fast)</option>
              </select>
            </div>

            <button id="start-btn" class="group relative w-full bg-red-600 hover:bg-red-500 text-white font-black py-4 rounded-xl text-xs transition-all shadow-xl shadow-red-600/20 uppercase tracking-[0.2em]">
              <span class="relative z-10">INITIALIZE ATTACK</span>
              <div class="absolute inset-0 bg-white/10 scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
            </button>

            <div class="pt-4 border-t border-white/5">
              <div class="flex items-center justify-between mb-4">
                <h4 class="text-[10px] font-black text-white/40 uppercase tracking-widest">DBMS Intel</h4>
                <div id="db-type" class="text-red-500 font-black text-[10px]">ANALYZING...</div>
              </div>
              <div class="h-[120px] flex items-center justify-center">
                <canvas id="dbChart"></canvas>
              </div>
            </div>

            <div class="pt-2 flex justify-between items-center px-1 border-t border-white/5 mt-4">
              <div class="flex items-center gap-2">
                <div id="bridge-dot" class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
                <span id="bridge-link" class="text-[9px] text-white/30 font-bold uppercase tracking-tighter">Bridge Link</span>
              </div>
              <span class="text-[9px] text-white/30 font-black uppercase tracking-widest">HACKIT v5.2</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Intelligence Hub -->
      <div class="lg:col-span-9 space-y-6">
        <!-- Tabs Navigation -->
        <div class="flex gap-2">
          <button class="tab-btn active px-6 py-3 bg-red-500 text-black text-[10px] font-black rounded-t-2xl uppercase tracking-widest transition-all" data-target="console">Tactical Console</button>
          <button class="tab-btn px-6 py-3 bg-dark-800 text-white/40 text-[10px] font-black rounded-t-2xl uppercase tracking-widest hover:text-white transition-all" data-target="explorer">Intelligence Explorer</button>
        </div>

        <div class="bg-dark-800/80 backdrop-blur-xl border border-white/10 rounded-3xl rounded-tl-none shadow-2xl overflow-hidden min-h-[600px] flex flex-col relative">
          
          <!-- Console View -->
          <div id="view-console" class="flex-grow flex flex-col">
            <div class="px-8 py-4 bg-white/[0.02] border-b border-white/5 flex items-center justify-between">
              <div class="text-[9px] font-black text-red-500 uppercase tracking-[0.2em]">Real-time Injection Stream</div>
              <div class="flex gap-2">
                <div class="w-2 h-2 rounded-full bg-red-500"></div>
                <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
              </div>
            </div>
            <div id="console-output" class="flex-grow p-8 font-mono text-[11px] space-y-2 bg-black/60 overflow-auto max-h-[500px]">
              <div class="text-white/20">[SYSTEM] Awaiting target for autonomous penetration...</div>
            </div>
            <!-- Quick Findings -->
            <div id="quick-findings" class="px-8 py-4 bg-red-500/5 border-t border-white/5 grid grid-cols-3 gap-4">
              <div class="p-3 bg-black/40 border border-white/5 rounded-xl">
                <div class="text-[8px] text-white/40 uppercase mb-1">Vuln Status</div>
                <div id="stat-vuln" class="text-xs font-black text-white/20">UNKNOWN</div>
              </div>
              <div class="p-3 bg-black/40 border border-white/5 rounded-xl">
                <div class="text-[8px] text-white/40 uppercase mb-1">DBMS Type</div>
                <div id="stat-db" class="text-xs font-black text-white/20">N/A</div>
              </div>
              <div class="p-3 bg-black/40 border border-white/5 rounded-xl">
                <div class="text-[8px] text-white/40 uppercase mb-1">Security Score</div>
                <div id="stat-score" class="text-xs font-black text-white/20">0/10</div>
              </div>
            </div>
          </div>

          <!-- Explorer View (Excel-like) -->
          <div id="view-explorer" class="hidden flex-grow flex flex-col">
            <div class="p-8 space-y-8 h-[600px] overflow-auto">
              <!-- Databases & Tables -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-4">
                  <h4 class="text-[10px] font-black text-yellow-500 uppercase tracking-widest">Discovered Databases</h4>
                  <div id="db-list" class="flex flex-wrap gap-2">
                    <span class="text-white/20 italic text-[10px]">No databases discovered yet...</span>
                  </div>
                </div>
                <div class="space-y-4">
                  <h4 class="text-[10px] font-black text-cyan-500 uppercase tracking-widest">Target Tables</h4>
                  <div id="table-list" class="flex flex-wrap gap-2">
                    <span class="text-white/20 italic text-[10px]">Select a database to view tables...</span>
                  </div>
                </div>
              </div>

              <!-- Data Grid -->
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="text-[10px] font-black text-green-500 uppercase tracking-widest">Exfiltrated Data Stream (Excel Mode)</h4>
                  <button class="text-[9px] font-black text-white/40 hover:text-white uppercase tracking-widest flex items-center gap-2 border border-white/10 px-3 py-1 rounded hover:bg-white/5">
                    Download CSV
                  </button>
                </div>
                <div class="border border-white/10 rounded-2xl overflow-hidden bg-black/40">
                  <table class="w-full text-left border-collapse">
                    <thead id="table-head" class="bg-white/[0.05] border-b border-white/10">
                      <tr>
                        <th class="px-6 py-4 text-[10px] font-black text-white/40 uppercase tracking-widest">ID</th>
                        <th class="px-6 py-4 text-[10px] font-black text-white/40 uppercase tracking-widest">Field_01</th>
                        <th class="px-6 py-4 text-[10px] font-black text-white/40 uppercase tracking-widest">Field_02</th>
                        <th class="px-6 py-4 text-[10px] font-black text-white/40 uppercase tracking-widest">Field_03</th>
                      </tr>
                    </thead>
                    <tbody id="table-body" class="divide-y divide-white/5">
                      <tr>
                        <td colspan="4" class="px-6 py-20 text-center text-white/10 italic text-xs uppercase tracking-widest">Initialize Attack to Extract Content</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    let chart;
    let scanInterval;
    const API_PORT = 8080;
    const API_PATHS = [`http://127.0.0.1:${API_PORT}`, `http://localhost:${API_PORT}`];

    function initChart(dataMap = {}) {
      const ctx = document.getElementById("dbChart").getContext("2d");
      if (chart) chart.destroy();
      const labels = Object.keys(dataMap).length > 0 ? Object.keys(dataMap) : ["WAITING"];
      const values = Object.keys(dataMap).length > 0 ? Object.values(dataMap) : [1];
      chart = new Chart(ctx, {
        type: "doughnut",
        data: {
          labels: labels,
          datasets: [{
            data: values,
            backgroundColor: ["#ef4444", "#3b82f6", "#10b981", "#6366f1", "#f59e0b"],
            borderWidth: 0,
            cutout: '80%'
          }],
        },
        options: {
          plugins: { legend: { display: false } },
          animation: { duration: 1000 },
          transitions: { active: { animation: { duration: 300 } } }
        },
      });
    }

    async function checkBridge() {
      const statusBtn = document.getElementById("bridge-link");
      const dot = document.getElementById("bridge-dot");
      for (const path of API_PATHS) {
        try {
          const res = await fetch(`${path}/api/ping`, { mode: "cors", signal: AbortSignal.timeout(3000) });
          if (res.ok) {
            statusBtn.innerHTML = "BRIDGE LINKED";
            statusBtn.className = "text-[9px] text-green-500 font-black";
            dot.className = "w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_5px_#22c55e]";
            return path;
          }
        } catch (e) {}
      }
      statusBtn.innerHTML = "BRIDGE OFFLINE";
      statusBtn.className = "text-[9px] text-red-500 font-black";
      dot.className = "w-1.5 h-1.5 rounded-full bg-red-500";
      return null;
    }

    function addLog(msg, color = 'text-white/40') {
      const el = document.getElementById('console-output');
      const div = document.createElement('div');
      div.className = `${color} leading-relaxed`;
      div.style.animation = 'fadeSlideIn 0.3s ease-out';
      div.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
    }

    // Tab Logic
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active', 'bg-red-500', 'text-black');
          b.classList.add('bg-dark-800', 'text-white/40');
        });
        btn.classList.add('active', 'bg-red-500', 'text-black');
        btn.classList.remove('bg-dark-800', 'text-white/40');
        
        const target = btn.dataset.target;
        document.getElementById('view-console').classList.toggle('hidden', target !== 'console');
        document.getElementById('view-explorer').classList.toggle('hidden', target !== 'explorer');
      });
    });

    function simulateProgress() {
      const msgs = [
        ['SCANNING: Probing parameter reflection...', 'text-white/60'],
        ['SCANNING: Testing error-based injection vectors...', 'text-white/60'],
        ['SCANNING: Checking blind SQL patterns...', 'text-white/60'],
        ['SCANNING: Analyzing response differentials...', 'text-white/60'],
        ['SCANNING: Attempting UNION-based extraction...', 'text-yellow-500'],
        ['SCANNING: Fingerprinting database backend...', 'text-white/60'],
        ['SCANNING: Extracting table schemas...', 'text-white/60'],
      ];
      let i = 0;
      scanInterval = setInterval(() => {
        if (i < msgs.length) {
          addLog(msgs[i][0], msgs[i][1]);
          i++;
        } else {
          clearInterval(scanInterval);
        }
      }, 600);
    }

    async function runSqliScan() {
      const url = document.getElementById("target-url").value.trim();
      if (!url) return alert("Enter target URL");

      const activePath = await checkBridge();
      if (!activePath) return alert('API Bridge Offline. Start backend on port 8080.');

      const btn = document.getElementById("start-btn");
      const badge = document.getElementById("status-badge");
      const consoleEl = document.getElementById("console-output");
      
      const dbList = document.getElementById("db-list");
      const tableList = document.getElementById("table-list");
      const tableHead = document.getElementById("table-head");
      const tableBody = document.getElementById("table-body");

      btn.disabled = true;
      btn.innerHTML = '<span class="animate-pulse">⚡ ATTACKING...</span>';
      badge.classList.remove("hidden");
      consoleEl.innerHTML = '';
      dbList.innerHTML = '<span class="text-white/20 italic text-[10px]">Exfiltrating databases...</span>';
      tableList.innerHTML = '<span class="text-white/20 italic text-[10px]">Awaiting schema...</span>';

      addLog(`Initializing Autonomous Penetration for: ${url}`, 'text-red-500 font-black');
      addLog("PHASE 1: Identifying injection vectors...");
      simulateProgress();

      try {
        const response = await fetch(`${activePath}/api/sqli?url=${encodeURIComponent(url)}`, {
          method: "GET",
          headers: { Accept: "application/json" },
          mode: "cors",
          signal: AbortSignal.timeout(30000),
        });

        clearInterval(scanInterval);
        const data = await response.json();
        if (data.error) throw new Error(data.error);

        if (data.vuln) {
          addLog(`SUCCESS: Target VULNERABLE via ${data.findings[0].type}`, "text-green-400 font-black");
          document.getElementById('stat-vuln').textContent = "VULNERABLE";
          document.getElementById('stat-vuln').className = "text-xs font-black text-red-500 animate-pulse";
          document.getElementById('stat-db').textContent = data.findings[0].dbms.toUpperCase();
          document.getElementById('stat-db').className = "text-xs font-black text-cyan-400";
          document.getElementById('stat-score').textContent = "9.4 / 10";
          document.getElementById('stat-score').className = "text-xs font-black text-red-500";
          document.getElementById('db-type').textContent = data.findings[0].dbms.toUpperCase();

          addLog(`PHASE 2: Auto-Exfiltrating database schema...`, "text-yellow-500 font-bold");
          
          dbList.innerHTML = '';
          data.explorer.databases.forEach((db, i) => {
            const span = document.createElement('span');
            span.className = "px-3 py-1 bg-red-500/10 border border-red-500/20 text-red-500 text-[10px] font-black rounded-lg uppercase cursor-pointer hover:bg-red-500 hover:text-black transition-all";
            span.style.animation = `fadeSlideIn 0.3s ease-out ${i * 0.1}s forwards`;
            span.style.opacity = '0';
            span.textContent = db;
            dbList.appendChild(span);
          });
          addLog(`Discovered ${data.explorer.databases.length} databases.`, "text-white/60");

          tableList.innerHTML = '';
          const firstDb = data.explorer.databases[0];
          if (data.explorer.tables[firstDb]) {
            data.explorer.tables[firstDb].forEach((table, i) => {
              const span = document.createElement('span');
              span.className = "px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-black rounded-lg uppercase cursor-pointer hover:bg-cyan-400 hover:text-black transition-all";
              span.style.animation = `fadeSlideIn 0.3s ease-out ${i * 0.08}s forwards`;
              span.style.opacity = '0';
              span.textContent = table;
              tableList.appendChild(span);
            });
            addLog(`Extracted ${data.explorer.tables[firstDb].length} tables from ${firstDb}.`, "text-white/60");
          }

          addLog(`PHASE 3: Dumping sample data records...`, "text-green-500 font-black");
          
          const sample = data.explorer.sample_data;
          if (sample.length > 0) {
            const headers = Object.keys(sample[0]);
            tableHead.innerHTML = `<tr>${headers.map(h => `<th class="px-6 py-4 text-[10px] font-black text-white/40 uppercase tracking-widest">${h}</th>`).join('')}</tr>`;
            tableBody.innerHTML = sample.map((row, i) => `
              <tr class="hover:bg-white/[0.02] transition-colors group" style="animation:fadeSlideIn 0.3s ease-out ${i * 0.05}s forwards;opacity:0">
                ${headers.map(h => `<td class="px-6 py-4 text-[10px] text-white/60 font-mono group-hover:text-white transition-colors">${row[h]}</td>`).join('')}
              </tr>
            `).join('');
          }
          
          addLog("AUTOMATED EXFILTRATION COMPLETE. Switch to 'Intelligence Explorer' to view data.", "text-red-500 font-black uppercase tracking-widest");
          initChart({ [data.findings[0].dbms]: 100 });
        } else {
          addLog("Result: Target is not vulnerable to SQL injection.", "text-white/40");
          document.getElementById('stat-vuln').textContent = "SECURE";
          document.getElementById('stat-vuln').className = "text-xs font-black text-green-500";
        }
      } catch (err) {
        clearInterval(scanInterval);
        addLog(`ERROR: ${err.message}`, "text-red-500 font-bold");
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span class="relative z-10">INITIALIZE ATTACK</span>';
        badge.classList.add("hidden");
      }
    }

    window.addEventListener("load", () => {
      initChart({});
      checkBridge();
      document.getElementById("start-btn").addEventListener("click", runSqliScan);
    });
  </script>

  <style>
    .tab-btn.active {
      box-shadow: 0 -5px 15px rgba(239, 68, 68, 0.2);
    }
    #console-output::-webkit-scrollbar { width: 4px; }
    #console-output::-webkit-scrollbar-thumb { background: rgba(239, 68, 68, 0.2); border-radius: 10px; }
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</Layout>
