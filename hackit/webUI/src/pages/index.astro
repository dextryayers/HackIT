---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HackIT OSINT | Launch Pad">
	<div class="max-w-5xl mx-auto p-12 space-y-10">
		<header class="space-y-2">
			<h2 class="text-3xl font-semibold text-sf-text tracking-tight">HackIT Command Center</h2>
			<p class="text-sf-muted text-sm">Initialize industrial-grade intelligence gathering against your target.</p>
		</header>

		<div class="bg-sf-card border border-sf-border rounded-xl p-10 relative overflow-hidden group">
			
			<div class="max-w-3xl space-y-8 relative z-10">
				<!-- Scan Target -->
				<div class="space-y-3">
					<label class="flex items-center gap-2 font-medium text-sm text-sf-text">
						Target Identifier
					</label>
					<div class="relative">
						<input 
							type="text" 
							id="target-input"
							placeholder="domain.com, IP, or Email" 
							class="w-full bg-sf-lightbg border border-sf-border rounded-md px-4 py-3 text-sm text-sf-text focus:outline-none focus:border-sf-muted focus:ring-1 focus:ring-sf-muted transition-all placeholder:text-sf-muted/50"
						/>
						<div class="absolute right-4 top-1/2 -translate-y-1/2 text-sf-muted/30 pointer-events-none">
							<i class="fas fa-keyboard"></i>
						</div>
					</div>
					<p class="text-xs text-sf-muted flex items-center gap-2">
						<i class="fas fa-info-circle opacity-50"></i> Supports Domains, IPv4/v6, Subnets, and Email addresses.
					</p>
				</div>

				<!-- Scan Options -->
				<div class="space-y-4 pt-2">
					<label class="flex items-center gap-2 font-medium text-sm text-sf-text">
						Mission Strategy
					</label>
					
					<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
						<!-- Option 1 -->
						<label class="border border-sf-text bg-sf-lightbg rounded-md p-4 cursor-pointer flex flex-col gap-2 relative transition-all">
							<div class="flex items-center justify-between">
								<span class="font-semibold text-sm text-sf-text">HackIT Full Scan</span>
								<input type="radio" name="scantype" checked class="w-4 h-4 accent-sf-text" />
							</div>
							<p class="text-[11px] text-sf-muted leading-relaxed">Engage all 100+ OSINT modules for total infrastructure transparency.</p>
						</label>
						
						<!-- Option 2 -->
						<label class="border border-sf-border bg-sf-lightbg hover:border-sf-muted rounded-md p-4 cursor-pointer flex flex-col gap-2 transition-all">
							<div class="flex items-center justify-between">
								<span class="font-medium text-sm text-sf-text">Passive Stealth</span>
								<input type="radio" name="scantype" class="w-4 h-4 accent-sf-text" />
							</div>
							<p class="text-[11px] text-sf-muted leading-relaxed">Zero-touch reconnaissance using only third-party data aggregators.</p>
						</label>

						<!-- Option 3 -->
						<label class="border border-sf-border bg-sf-lightbg hover:border-sf-muted rounded-md p-4 cursor-pointer flex flex-col gap-2 transition-all">
							<div class="flex items-center justify-between">
								<span class="font-medium text-sm text-sf-text">Threat Hunt</span>
								<input type="radio" name="scantype" class="w-4 h-4 accent-sf-text" />
							</div>
							<p class="text-[11px] text-sf-muted leading-relaxed">Focus exclusively on data breaches, malware, and C2 infrastructure.</p>
						</label>
					</div>
				</div>

				<!-- Actions -->
				<div class="pt-6 flex items-center gap-4 border-t border-sf-border">
					<button id="run-scan-btn" class="bg-sf-text text-sf-lightbg hover:bg-white px-6 py-2.5 rounded-md text-sm font-medium transition-all flex items-center gap-2">
						Initiate Scan
					</button>
					<button id="verbose-scan-btn" class="bg-sf-card border border-sf-border text-sf-text hover:border-sf-muted px-6 py-2.5 rounded-md text-sm font-medium transition-all flex items-center gap-2">
						Launch Verbose
					</button>
					<button class="text-sf-muted hover:text-sf-text text-sm transition-colors font-medium">
						Advanced Config
					</button>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		const runBtn = document.getElementById('run-scan-btn');
		const verboseBtn = document.getElementById('verbose-scan-btn');
		const targetInput = document.getElementById('target-input');
		
		function validateAndRun(redirectPath) {
			const target = targetInput.value.trim();
			if (!target) {
				targetInput.focus();
				targetInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
				setTimeout(() => targetInput.classList.remove('border-red-500', 'ring-2', 'ring-red-500/20'), 2000);
				return;
			}
			
			window.location.href = `${redirectPath}?target=${encodeURIComponent(target)}`;
		}

		runBtn.addEventListener('click', () => validateAndRun('/intelligence'));
		verboseBtn.addEventListener('click', () => validateAndRun('/log'));

		// Radio selection visual feedback
		const radios = document.querySelectorAll('input[name="scantype"]');
		radios.forEach(radio => {
			radio.addEventListener('change', (e) => {
				document.querySelectorAll('input[name="scantype"]').forEach(r => {
					r.closest('label').classList.remove('border-sf-text');
					r.closest('label').classList.add('border-sf-border');
					r.querySelector('span').classList.remove('font-semibold');
					r.querySelector('span').classList.add('font-medium');
				});
				if (e.target.checked) {
					e.target.closest('label').classList.remove('border-sf-border');
					e.target.closest('label').classList.add('border-sf-text');
					e.target.closest('label').querySelector('span').classList.remove('font-medium');
					e.target.closest('label').querySelector('span').classList.add('font-semibold');
				}
			});
		});
	</script>
</Layout>
