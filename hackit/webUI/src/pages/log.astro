---
import Layout from '../layouts/Layout.astro';
import TerminalLog from '../components/TerminalLog.astro';

// Get target from query params
const target = ""; // We'll handle this in the client side to avoid SSR complexity with the Python API
---

<Layout title="HackIT OSINT | Verbose Execution Log">
	<div class="h-[calc(100vh-64px)] flex flex-col p-8 space-y-6">
		<!-- Header -->
		<div class="flex items-center justify-between">
			<div class="space-y-1">
				<h1 class="text-xl font-semibold text-sf-text flex items-center gap-3">
					<i class="fas fa-terminal text-sf-muted text-sm"></i>
					Verbose Execution Log
				</h1>
				<p class="text-sf-muted text-xs">Real-time telemetry stream from the HackIT OSINT Engine.</p>
			</div>
			<div class="flex items-center gap-3">
				<button onclick="window.history.back()" class="px-4 py-1.5 bg-sf-card border border-sf-border text-sf-muted hover:text-sf-text rounded-md text-[10px] font-bold transition-all flex items-center gap-2">
					<i class="fas fa-arrow-left"></i> BACK TO COMMAND CENTER
				</button>
				<div class="h-4 w-px bg-sf-border mx-2"></div>
				<div id="target-badge" class="px-3 py-1 bg-sf-card border border-sf-border rounded-md text-[10px] font-mono text-sf-text uppercase tracking-widest">
					TARGET: PENDING
				</div>
			</div>
		</div>

		<!-- Main Terminal View -->
		<div class="flex-1 min-h-0" id="terminal-wrapper">
			<!-- TerminalLog will be injected here once we have a jobId -->
            <div class="w-full h-full flex items-center justify-center bg-sf-card border border-sf-border rounded-lg animate-pulse" id="init-loader">
                <div class="text-center space-y-4">
                    <div class="w-10 h-10 border-2 border-sf-text border-t-transparent rounded-full animate-spin mx-auto"></div>
                    <p class="text-[10px] font-mono text-sf-muted uppercase tracking-widest">Negotiating Handshake...</p>
                </div>
            </div>
		</div>
	</div>

	<script is:inline>
		async function initializeLogSession() {
			const urlParams = new URLSearchParams(window.location.search);
			const target = urlParams.get('target');
			const wrapper = document.getElementById('terminal-wrapper');
			const targetBadge = document.getElementById('target-badge');
			
			if (!target) {
				wrapper.innerHTML = `
					<div class="w-full h-full flex items-center justify-center bg-sf-card border border-sf-border rounded-lg">
						<div class="text-center space-y-4">
							<i class="fas fa-exclamation-circle text-red-500 text-2xl"></i>
							<p class="text-[10px] font-mono text-sf-muted uppercase tracking-widest">Error: No target specified in parameters.</p>
							<a href="/" class="inline-block px-4 py-2 bg-sf-text text-sf-lightbg rounded-md text-[10px] font-bold">RETURN HOME</a>
						</div>
					</div>
				`;
				return;
			}

			targetBadge.innerText = `TARGET: ${target}`;

			try {
				// Check for existing job first
				const existingRes = await fetch(`/api/job-by-target?target=${encodeURIComponent(target)}`);
				const existingJob = await existingRes.json();
				if (existingJob && existingJob.job_id) {
					window.TitanJobId = existingJob.job_id;
					window.TitanTarget = target;
					document.getElementById('init-loader').remove();
					renderTerminal(existingJob.job_id, target);
					if (existingJob.status === 'Completed' || existingJob.status === 'Error') {
						// Show all existing logs immediately
						const logStatus = document.getElementById('log-status');
						const logContainer = document.getElementById('log-container');
						const terminalBody = document.getElementById('terminal-body');
						const logCountEl = document.getElementById('log-count');
						if (existingJob.live_logs) {
							let c = 0;
							existingJob.live_logs.forEach(l => {
								const div = document.createElement('div');
								if (l.includes('[+]')) div.className = 'text-emerald-400';
								else if (l.includes('[!]')) div.className = 'text-red-400';
								else if (l.includes('[INFO]')) div.className = 'text-sf-tabActive';
								else div.className = 'text-sf-text opacity-90';
								div.innerText = l;
								logContainer.appendChild(div);
								c++;
							});
							terminalBody.scrollTop = terminalBody.scrollHeight;
							logCountEl.innerText = `LOGS: ${c}`;
						}
						logStatus.innerHTML = '<div class="w-1.5 h-1.5 rounded-full bg-sf-muted"></div> HackIT Intelligence Gathering Completed...';
					}
					return;
				}

				// No existing job — start new scan
				const savedSettings = localStorage.getItem('hackit_scan_settings');
				let scanUrl = `/api/scan?target=${encodeURIComponent(target)}`;
				if (savedSettings) {
					try {
						const s = JSON.parse(savedSettings);
						scanUrl += `&depth=${encodeURIComponent(s.depth || 'deep')}`;
						scanUrl += `&sniper_ratio=${encodeURIComponent(s.sniperRatio || 'max')}`;
						scanUrl += `&timeout=${encodeURIComponent(s.timeout || 15)}`;
						scanUrl += `&verbose=${encodeURIComponent(s.verbose ?? 1)}`;
						scanUrl += `&max_findings=${encodeURIComponent(s.maxFindings || 5000)}`;
						scanUrl += `&format=${encodeURIComponent(s.exportFormat || 'json')}`;
						if (s.modules) {
							const activeModules = Object.entries(s.modules).filter(([,v]) => v).map(([k]) => k).join(',');
							if (activeModules) scanUrl += `&modules=${encodeURIComponent(activeModules)}`;
						}
						if (s.toggles) {
							Object.entries(s.toggles).forEach(([k, v]) => {
								scanUrl += `&${encodeURIComponent(k)}=${v ? '1' : '0'}`;
							});
						}
					} catch(e) {}
				}
				const res = await fetch(scanUrl);
				const data = await res.json();
				
				if (data.job_id) {
                    window.TitanJobId = data.job_id;
                    window.TitanTarget = target;
                    document.getElementById('init-loader').remove();
                    renderTerminal(data.job_id, target);
				}
			} catch (err) {
				console.error('Initialization failed:', err);
			}
		}

        function renderTerminal(jobId, target) {
            const wrapper = document.getElementById('terminal-wrapper');
            wrapper.innerHTML = `
                <div class="bg-[#050505] border border-sf-border rounded-lg overflow-hidden flex flex-col h-full shadow-2xl">
                    <div class="bg-sf-card border-b border-sf-border px-4 py-2 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <div class="flex gap-1.5">
                                <div class="w-2.5 h-2.5 rounded-full bg-red-500/20 border border-red-500/40"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/20 border border-yellow-500/40"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/20 border border-emerald-500/40"></div>
                            </div>
                            <span class="text-[10px] font-mono text-sf-muted ml-2 uppercase tracking-widest">HackIT Engine v2.1 — ${target}</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <span id="log-status" class="text-[10px] font-mono text-sf-muted uppercase tracking-widest flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-sf-green animate-pulse"></div> HackIT Intelligence Gathering in Progress...
                            </span>
                            <button id="clear-terminal" class="text-[10px] font-mono text-sf-muted hover:text-sf-text transition-colors uppercase tracking-widest">Clear</button>
                        </div>
                    </div>
                    <div id="terminal-body" class="flex-1 p-6 font-mono text-[11px] overflow-auto leading-relaxed scroll-smooth">
                        <div class="space-y-1" id="log-container">
                            <div class="text-sf-muted">[SYSTEM] INITIALIZING HACKIT OSINT ORCHESTRATOR...</div>
                            <div class="text-sf-text font-bold">[GATEWAY] JOB_ID: ${jobId}</div>
                        </div>
                    </div>
                    <div class="bg-sf-card border-t border-sf-border px-4 py-2 flex justify-between items-center text-[9px] font-mono text-sf-muted uppercase tracking-widest">
                        <div class="flex gap-4"><span>CPU: 28%</span><span>MEM: 96MB</span><span>TRH: 50</span></div>
                        <div id="log-count">LOGS: 0</div>
                    </div>
                </div>
            `;

            const logContainer = document.getElementById('log-container');
            const terminalBody = document.getElementById('terminal-body');
            const logStatus = document.getElementById('log-status');
            const logCountEl = document.getElementById('log-count');
            
            let processedLogs = new Set();
            let logCount = 0;

            const append = (msg) => {
                const div = document.createElement('div');
                if (msg.includes('[+]')) div.className = 'text-emerald-400';
                else if (msg.includes('[!]')) div.className = 'text-red-400';
                else if (msg.includes('[INFO]')) div.className = 'text-sf-tabActive';
                else div.className = 'text-sf-text opacity-90';
                div.innerText = msg;
                logContainer.appendChild(div);
                terminalBody.scrollTop = terminalBody.scrollHeight;
                logCount++;
                logCountEl.innerText = `LOGS: ${logCount}`;
            };

            const poll = setInterval(async () => {
                try {
                    const res = await fetch(`/api/status?job_id=${jobId}`);
                    const data = await res.json();
                    if (data.live_logs) {
                        data.live_logs.forEach(l => {
                            if (!processedLogs.has(l)) {
                                append(l);
                                processedLogs.add(l);
                            }
                        });
                    }
                    if (data.status === 'Completed' || data.status === 'Error') {
                        clearInterval(poll);
                        logStatus.innerHTML = '<div class="w-1.5 h-1.5 rounded-full bg-sf-muted"></div> HackIT Intelligence Gathering Completed...';
                    }
                } catch (e) {}
            }, 1000);
        }

		initializeLogSession();
	</script>
</Layout>
