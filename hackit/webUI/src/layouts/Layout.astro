---
import '../styles/global.css';
interface Props {
	title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="HackIT OSINT Engine – Multi-vector Intelligence Gathering Platform" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/logo.ico" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="astro-view-transitions-enabled" content="true" />
		<title>{title}</title>

		<!-- Third-party -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
		<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" is:inline></script>
		<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js" is:inline></script>
		<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js" is:inline defer></script>
		<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />

		<!-- JS Helpers -->
		<script src="/js/utils.js" type="module"></script>
		<script src="/js/api.js" type="module"></script>
		<script src="/js/ws.js" type="module"></script>
		<script src="/js/scan-client.js" type="module"></script>

		<script is:inline>
			(function() {
				const theme = localStorage.getItem('hackit_theme');
				if (theme === 'light') {
					document.documentElement.classList.remove('dark');
					document.documentElement.classList.add('light');
				} else if (theme === 'dark' || !window.matchMedia('(prefers-color-scheme: light)').matches) {
					document.documentElement.classList.remove('light');
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
					document.documentElement.classList.add('light');
				}
			})();
		</script>
	</head>
	<body class="bg-sf-lightbg text-sf-text overflow-x-hidden text-sm h-screen flex flex-col">
		<!-- Navbar -->
		<header class="bg-sf-lightbg/80 backdrop-blur-lg border-b border-sf-border sticky top-0 z-50">
			<div class="px-6 h-14 flex items-center justify-between max-w-7xl mx-auto w-full">
				<div class="flex items-center gap-8">
					<a href="/" class="flex items-center gap-2.5">
						<div class="p-1.5 bg-sf-card border border-sf-border rounded-lg">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
						</div>
						<span class="text-base font-semibold tracking-tight">HackIT <span class="font-normal text-sf-muted">OSINT</span></span>
					</a>
					<nav class="hidden md:flex items-center gap-1">
						{[
							{ href: '/', label: 'Launch Pad', icon: 'fa-rocket' },
							{ href: '/intelligence', label: 'Intelligence', icon: 'fa-brain' },
							{ href: '/scans', label: 'Scans', icon: 'fa-list' },
							{ href: '/settings', label: 'Settings', icon: 'fa-cog' },
						].map(item => (
							<a href={item.href}
								aria-label={`Navigate to ${item.label}`}
								class:list={[
									'px-3.5 py-1.5 rounded-lg flex items-center gap-2 text-sm font-medium transition-all',
									currentPath === item.href
										? 'bg-sf-card text-sf-tabActive'
										: 'text-sf-muted hover:text-sf-text hover:bg-sf-card/50'
								]}>
								<i class={`fas ${item.icon} text-xs opacity-70`}></i>
								{item.label}
							</a>
						))}
					</nav>
				</div>
				<div class="flex items-center gap-3">
					<button id="theme-toggle" aria-label="Toggle dark/light theme" class="w-8 h-8 rounded-lg border border-sf-border bg-sf-card flex items-center justify-center hover:border-sf-muted transition-all text-xs">
						<i class="fas fa-moon dark:hidden"></i>
						<i class="fas fa-sun hidden dark:block text-yellow-400"></i>
					</button>
					<div class="h-6 w-px bg-sf-border"></div>
					<div class="flex items-center gap-2 px-3 py-1.5 bg-sf-card border border-sf-border rounded-lg text-xs">
						<div class="w-1.5 h-1.5 rounded-full bg-sf-green animate-pulse"></div>
						<span class="text-sf-muted">Online</span>
					</div>
					<button aria-label="User profile" class="w-8 h-8 rounded-full bg-sf-accent/20 border border-sf-accent/30 flex items-center justify-center text-sf-accent hover:bg-sf-accent hover:text-white transition-all text-xs">
						<i class="fas fa-user-secret"></i>
					</button>
				</div>
			</div>
		</header>

		<!-- Mobile Nav -->
		<nav class="md:hidden flex items-center gap-1 px-4 py-2 border-b border-sf-border bg-sf-lightbg/80 backdrop-blur-lg overflow-x-auto">
			{[
				{ href: '/', label: 'Launch', icon: 'fa-rocket' },
				{ href: '/intelligence', label: 'Intel', icon: 'fa-brain' },
				{ href: '/scans', label: 'Scans', icon: 'fa-list' },
				{ href: '/settings', label: 'Settings', icon: 'fa-cog' },
			].map(item => (
				<a href={item.href}
					aria-label={`Navigate to ${item.label}`}
					class:list={[
						'px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-all',
						currentPath === item.href
							? 'bg-sf-card text-sf-tabActive'
							: 'text-sf-muted hover:text-sf-text'
					]}>
					<i class={`fas ${item.icon} mr-1.5`}></i>
					{item.label}
				</a>
			))}
		</nav>

		<!-- Main -->
		<main class="flex-1 overflow-y-auto">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="border-t border-sf-border bg-sf-lightbg/50 py-2.5 px-6 text-center">
			<p class="text-[10px] text-sf-muted tracking-wider">
				&copy; 2026 			<a href="https://haniipp.space" target="_blank" aria-label="Hanif Abdurrohim's website" class="text-sf-tabActive hover:underline">Hanif Abdurrohim</a>
				&mdash; Built for the security community.
			</p>
		</footer>

		<!-- Cookie Banner -->
		<div id="cookie-banner" class="fixed bottom-4 left-1/2 -translate-x-1/2 z-[999] max-w-lg w-[92%] bg-sf-card border border-sf-border rounded-xl shadow-2xl p-4 hidden">
			<div class="flex items-center gap-3">
				<div class="w-8 h-8 rounded-full bg-sf-tabActive/10 flex items-center justify-center shrink-0">
					<svg class="w-4 h-4 text-sf-tabActive" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
				</div>
				<p class="text-xs text-sf-muted leading-relaxed flex-1">
					Built by <strong class="text-sf-tabActive">Hanif Abdurrohim</strong>. Use responsibly on authorized targets only.
				</p>
				<button id="cookie-accept" aria-label="Accept cookie notice" class="shrink-0 px-4 py-1.5 bg-sf-tabActive text-black text-xs font-bold rounded-lg hover:opacity-90 transition-all">
					OK
				</button>
			</div>
		</div>

		<script is:inline>
			// Theme toggle
			document.getElementById('theme-toggle')?.addEventListener('click', () => {
				const isLight = document.documentElement.classList.toggle('light');
				document.documentElement.classList.toggle('dark', !isLight);
				localStorage.setItem('hackit_theme', isLight ? 'light' : 'dark');
			});

			// Cookie banner
			(function() {
				const banner = document.getElementById('cookie-banner');
				const btn = document.getElementById('cookie-accept');
				if (banner && btn) {
					if (!localStorage.getItem('hackit_consent')) {
						setTimeout(() => banner.classList.remove('hidden'), 600);
					}
					btn.addEventListener('click', () => {
						localStorage.setItem('hackit_consent', '1');
						banner.style.opacity = '0';
						setTimeout(() => banner.classList.add('hidden'), 300);
					});
				}
			})();

			// GSAP entry animations
			window.addEventListener('load', () => {
				if (typeof gsap !== 'undefined') {
					gsap.from('main > *', { opacity: 0, y: 16, duration: 0.6, ease: 'power2.out', stagger: 0.05 });
				}
			});
		</script>

		<!-- Toast Notification System -->
		<div id="toast-container" class="fixed top-20 right-6 z-[200] space-y-3 pointer-events-none">
		</div>
		<script is:inline>
		function showToast(message, type = 'info', duration = 4000) {
			const container = document.getElementById('toast-container');
			if (!container) return;
			const colors = { success: 'border-emerald-500 bg-emerald-500/10', error: 'border-red-500 bg-red-500/10', info: 'border-sky-500 bg-sky-500/10', warning: 'border-amber-500 bg-amber-500/10' };
			const icons = { success: 'fa-check-circle text-emerald-400', error: 'fa-exclamation-circle text-red-400', info: 'fa-info-circle text-sky-400', warning: 'fa-exclamation-triangle text-amber-400' };
			const toast = document.createElement('div');
			toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 bg-sf-card border ${colors[type]} rounded-lg shadow-2xl transform translate-x-full transition-transform duration-300 max-w-sm`;
			toast.innerHTML = `<i class="fas ${icons[type]} text-sm"></i><span class="text-xs text-sf-text font-medium">${message}</span>`;
			container.appendChild(toast);
			requestAnimationFrame(() => toast.classList.remove('translate-x-full'));
			setTimeout(() => { toast.classList.add('translate-x-full'); setTimeout(() => toast.remove(), 300); }, duration);
		}
		window.showToast = showToast;
		</script>
	</body>
</html>
