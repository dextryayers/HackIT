---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import TerminalOutput from "../components/TerminalOutput.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Input from "../components/ui/Input.astro";
---

<Layout title="Recon">
  <Navbar slot="nav" active="/recon" />

  <div class="animate-fade-in">
    <div class="flex items-center gap-4 mb-8">
      <div class="w-12 h-12 rounded-2xl bg-card flex items-center justify-center text-white shadow-lg shadow-md shrink-0">
        <i data-lucide="search" class="w-5 h-5"></i>
      </div>
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight bg-card bg-clip-text text-transparent">Reconnaissance</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Network Discovery &mdash; scan access points and hunt clients</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <!-- AP Scanner Card -->
      <Card variant="gradient" class="group hover:border-primary/20 hover:shadow-md">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="absolute top-0 left-0 w-full h-0.5 bg-card
        <div class="relative z-10 p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-card flex items-center justify-center text-white shadow-md">
              <i data-lucide="smartphone" class="w-4 h-4"></i>
            </div>
            <div>
              <h2 class="text-sm font-bold text-foreground">AP Scanner</h2>
              <p class="text-[11px] text-muted-foreground">Discover access points in range</p>
            </div>
          </div>

          <form id="crawl-form" onsubmit="runRecon('crawl'); return false">
            <div class="space-y-4">
              <Input label="Interface" type="text" name="iface" value="wlan0" />
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="text-xs text-muted-foreground mb-1.5 block font-medium">Band</label>
                  <select name="band" class="flex h-10 w-full rounded-xl border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all">
                    <option value="both">Both (2.4 + 5 GHz)</option>
                    <option value="2ghz">2.4 GHz</option>
                    <option value="5ghz">5 GHz</option>
                  </select>
                </div>
                <Input label="Timeout (sec)" type="number" name="timeout" value="15" />
              </div>
              <Button variant="gradient" type="submit" id="crawl-submit" class="w-full group/btn">
                <span class="absolute inset-0 bg-card -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></span>
                <i data-lucide="search" class="w-4 h-4"></i>
                <span>Start Scan</span>
              </Button>
            </div>
          </form>

          <!-- AP Results -->
          <div id="ap-results" class="mt-5 hidden animate-slide-up">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs text-muted-foreground font-medium flex items-center gap-2">
                <i data-lucide="search" class="w-3.5 h-3.5 text-emerald-500"></i>
                Found <span id="ap-count" class="text-foreground font-bold">0</span> APs
              </span>
            </div>
            <div class="overflow-x-auto rounded-xl border border-border">
              <table class="w-full text-xs">
                <thead>
                  <tr class="bg-muted/50 text-muted-foreground uppercase tracking-wider text-[11px]">
                    <th class="px-3 py-2.5 text-left font-semibold">SSID</th>
                    <th class="px-3 py-2.5 text-left font-semibold">BSSID</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Ch</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Signal</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Security</th>
                  </tr>
                </thead>
                <tbody id="ap-tbody"></tbody>
              </table>
            </div>
          </div>

          <!-- AP Loading -->
          <div id="ap-loading" class="mt-5 hidden">
            <div class="flex flex-col items-center py-6">
              <div class="relative w-12 h-12 mb-3">
                <div class="absolute inset-0 rounded-full border-2 border-primary/20 border-t-primary animate-spin"></div>
                <div class="absolute inset-1 rounded-full border-2 border-emerald-500/20 border-b-emerald-500 animate-spin-slow"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <i data-lucide="search" class="w-4 h-4 text-primary"></i>
                </div>
              </div>
              <p class="text-xs text-muted-foreground font-medium">Scanning for access points...</p>
            </div>
          </div>
        </div>
      </Card>

      <!-- Client Hunt Card -->
      <Card variant="gradient" class="group hover:border-violet-500/20 hover:shadow-md">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="absolute top-0 left-0 w-full h-0.5 bg-card
        <div class="relative z-10 p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-card flex items-center justify-center text-white shadow-md">
              <i data-lucide="users" class="w-4 h-4"></i>
            </div>
            <div>
              <h2 class="text-sm font-bold text-foreground">Client Hunt</h2>
              <p class="text-[11px] text-muted-foreground">Enumerate clients on target AP</p>
            </div>
          </div>

          <form id="hunt-form" onsubmit="runRecon('client-hunt'); return false">
            <div class="space-y-4">
              <Input label="Interface" type="text" name="iface" value="wlan0" />
              <Input label="BSSID" type="text" name="bssid" class="font-mono" placeholder="AA:BB:CC:DD:EE:FF" />
              <Input label="Timeout (sec)" type="number" name="timeout" value="30" />
              <Button variant="gradient" type="submit" id="hunt-submit" class="w-full group/btn">
                <span class="absolute inset-0 bg-card -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></span>
                <i data-lucide="search" class="w-4 h-4"></i>
                <span>Start Hunt</span>
              </Button>
            </div>
          </form>

          <!-- Client Results -->
          <div id="client-results" class="mt-5 hidden animate-slide-up">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs text-muted-foreground font-medium flex items-center gap-2">
                <i data-lucide="users" class="w-3.5 h-3.5 text-violet-500"></i>
                Found <span id="client-count" class="text-foreground font-bold">0</span> clients
              </span>
            </div>
            <div class="overflow-x-auto rounded-xl border border-border">
              <table class="w-full text-xs">
                <thead>
                  <tr class="bg-muted/50 text-muted-foreground uppercase tracking-wider text-[11px]">
                    <th class="px-3 py-2.5 text-left font-semibold">MAC</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Vendor</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Signal</th>
                    <th class="px-3 py-2.5 text-left font-semibold">Probes</th>
                  </tr>
                </thead>
                <tbody id="client-tbody"></tbody>
              </table>
            </div>
          </div>

          <!-- Client Loading -->
          <div id="client-loading" class="mt-5 hidden">
            <div class="flex flex-col items-center py-6">
              <div class="relative w-12 h-12 mb-3">
                <div class="absolute inset-0 rounded-full border-2 border-violet-500/20 border-t-violet-500 animate-spin"></div>
                <div class="absolute inset-1 rounded-full border-2 border-pink-500/20 border-b-pink-500 animate-spin-slow"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <i data-lucide="users" class="w-4 h-4 text-violet-500"></i>
                </div>
              </div>
              <p class="text-xs text-muted-foreground font-medium">Hunting for clients...</p>
            </div>
          </div>
        </div>
      </Card>
    </div>

    <TerminalOutput id="recon-terminal" height="350px" label="RECON OUTPUT" />
  </div>
</Layout>

<script>
function signalBarsHtml(sigValue) {
  const signalBars = sigValue >= -50 ? 4 : sigValue >= -60 ? 3 : sigValue >= -70 ? 2 : sigValue >= -80 ? 1 : 0;
  const barColor = signalBars === 4 ? 'bg-emerald-500' :
                   signalBars === 3 ? 'bg-amber-400' :
                   signalBars === 2 ? 'bg-orange-500' : 'bg-red-500';
  return '<span class="inline-flex items-end gap-[2px] h-3 mr-1.5">' +
    [1,2,3,4].map((_, j) =>
      `<span class="w-[3px] rounded-sm transition-all ${j < signalBars ? barColor : 'bg-border'}" style="height:${4 + j * 3}px"></span>`
    ).join('') + '</span>';
}

async function runRecon(type) {
  const isCrawl = type === 'crawl';
  const formId = isCrawl ? 'crawl-form' : 'hunt-form';
  const submitId = isCrawl ? 'crawl-submit' : 'hunt-submit';
  const resultsId = isCrawl ? 'ap-results' : 'client-results';
  const loadingId = isCrawl ? 'ap-loading' : 'client-loading';
  const tbodyId = isCrawl ? 'ap-tbody' : 'client-tbody';
  const countId = isCrawl ? 'ap-count' : 'client-count';

  const f = document.getElementById(formId);
  const submitBtn = document.getElementById(submitId);
  const fd = new FormData(f);
  const data = {};
  for (const [k, v] of fd) data[k] = v;

  const { isConfirmed } = await HackitUI.confirm({
    title: isCrawl ? 'Start AP Scan?' : 'Start Client Hunt?',
    text: isCrawl ? `Scan on ${data.iface || 'wlan0'} for ${data.timeout || 15}s` : `Hunt on ${data.iface || 'wlan0'} for BSSID ${data.bssid || '(any)'}`,
    icon: 'question',
    confirmButtonColor: isCrawl ? '#00d4ff' : '#b026ff',
    cancelButtonColor: '#1e293b',
    confirmButtonText: `<span class="flex items-center gap-2">${isCrawl ? 'Scan' : 'Hunt'}</span>`,
    background: 'rgba(10,10,26,0.95)',
    color: '#f8fafc',
    backdrop: 'rgba(0,0,0,0.7)',
    customClass: { popup: 'rounded-2xl border border-border' }
  });
  if (!isConfirmed) return;

  submitBtn.disabled = true;
  submitBtn.innerHTML = '<span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span> Running...';

  document.getElementById(resultsId)?.classList.add('hidden');
  document.getElementById(loadingId)?.classList.remove('hidden');

  window.clearTerminal?.();
  window.appendTerminal?.(`<span class="text-yellow-400">Starting ${type}...</span>`);
  window.appendTerminal?.(`<span class="text-muted-foreground">Interface: ${data.iface || 'wlan0'}</span>`);

  try {
    const r = await fetch(`/api/recon/${type}`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    const result = await r.json();

    document.getElementById(loadingId)?.classList.add('hidden');

    if (result.stdout) window.appendTerminal?.(result.stdout);
    if (result.stderr) window.appendTerminal?.(`<span class="text-red-500">${result.stderr}</span>`);
    window.appendTerminal?.(`<span class="text-emerald-500">[DONE] exit code: ${result.code}</span>`);

    if (isCrawl && result.aps && result.aps.length) {
      document.getElementById(countId).textContent = result.aps.length;
      document.getElementById(tbodyId).innerHTML = result.aps.map((ap, i) => {
        const sig = ap.signal_rust ?? ap.signal;
        const sigStr = ap.signal_rust != null ? sig + ' dBm' : sig + '%';
        const sigColor = sig >= -60 ? 'text-emerald-500' : sig >= -70 ? 'text-amber-400' : sig >= -80 ? 'text-orange-500' : 'text-red-500';
        return `<tr class="${i % 2 === 0 ? 'bg-transparent' : 'bg-muted/20'} border-b border-border/40 hover:bg-primary/[0.03] transition-colors">
          <td class="px-3 py-2.5 text-foreground font-medium">${ap.ssid || '<span class="text-muted-foreground/40 italic">hidden</span>'}</td>
          <td class="px-3 py-2.5 font-mono text-muted-foreground">${(ap.bssid || '').replace(/\\\\:/g, ':')}</td>
          <td class="px-3 py-2.5 text-muted-foreground">${ap.channel}</td>
          <td class="px-3 py-2.5"><div class="flex items-center gap-1 ${sigColor} font-mono">${signalBarsHtml(sig)}<span>${sigStr}</span></div></td>
          <td class="px-3 py-2.5 text-muted-foreground">${ap.security || '?'}</td>
        </tr>`;
      }).join('');
      document.getElementById(resultsId)?.classList.remove('hidden');
      HackitUI.success(`${result.aps.length} APs Found`);
    } else if (!isCrawl && result.clients && result.clients.length) {
      document.getElementById(countId).textContent = result.clients.length;
      document.getElementById(tbodyId).innerHTML = result.clients.map((c, i) => {
        const sig = c.signal ?? c.rssi ?? 0;
        const sigStr = sig + ' dBm';
        const sigColor = sig >= -60 ? 'text-emerald-500' : sig >= -70 ? 'text-amber-400' : sig >= -80 ? 'text-orange-500' : 'text-red-500';
        return `<tr class="${i % 2 === 0 ? 'bg-transparent' : 'bg-muted/20'} border-b border-border/40 hover:bg-primary/[0.03] transition-colors">
          <td class="px-3 py-2.5 font-mono text-foreground font-medium">${c.mac || c.bssid || '?'}</td>
          <td class="px-3 py-2.5 text-muted-foreground">${c.vendor || '-'}</td>
          <td class="px-3 py-2.5"><div class="flex items-center gap-1 ${sigColor} font-mono">${signalBarsHtml(sig)}<span>${sigStr}</span></div></td>
          <td class="px-3 py-2.5 text-muted-foreground">${c.probes ? c.probes.join(', ') : '-'}</td>
        </tr>`;
      }).join('');
      document.getElementById(resultsId)?.classList.remove('hidden');
      HackitUI.success(`${result.clients.length} Clients Found`);
    } else {
      HackitUI.info('No Results', 'Nothing found. Check parameters.');
    }
  } catch (e) {
    document.getElementById(loadingId)?.classList.add('hidden');
    window.appendTerminal?.(`<span class="text-red-500">Error: ${e.message}</span>`);
    HackitUI.error('Failed', e.message);
  }

  submitBtn.disabled = false;
  submitBtn.innerHTML = isCrawl
    ? '<i data-lucide="search" class="w-4 h-4"></i> Start Scan'
    : '<i data-lucide="search" class="w-4 h-4"></i> Start Hunt';
}
</script>
