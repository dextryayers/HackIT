---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import AttackCard from "../components/AttackCard.astro";
import TerminalOutput from "../components/TerminalOutput.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";

const attacks = [
  { name: "deauth", label: "Deauth Attack", desc: "Send 802.11 deauth frames to disconnect clients from an AP", icon: "zap" },
  { name: "beacon-flood", label: "Beacon Flood", desc: "Flood airwaves with fake beacon frames", icon: "radio" },
  { name: "probe-flood", label: "Probe Flood", desc: "Overwhelm APs with probe requests", icon: "activity" },
  { name: "eviltwin", label: "Evil Twin", desc: "Clone SSID and deploy rogue AP with captive portal", icon: "copy" },
  { name: "rogue", label: "Rogue AP", desc: "Broadcast a fake access point", icon: "wifi" },
  { name: "arp-spoof", label: "ARP Spoof", desc: "Poison ARP cache for MITM interception", icon: "share-2" },
  { name: "handshake", label: "Handshake Capture", desc: "Capture WPA/WPA2 4-way handshake", icon: "shield" },
  { name: "pmkid", label: "PMKID Capture", desc: "Capture PMKID hash for offline cracking", icon: "key" },
  { name: "wps-pixie", label: "WPS PixieDust", desc: "Recover WPS PIN via PixieDust attack", icon: "unlock" },
  { name: "wps-bruteforce", label: "WPS Bruteforce", desc: "Bruteforce WPS PIN of target AP", icon: "hash" },
  { name: "wep-arp", label: "WEP ARP Replay", desc: "Generate WEP IVs via ARP replay", icon: "repeat" },
  { name: "wep-chopchop", label: "WEP ChopChop", desc: "Decrypt WEP without the key", icon: "scissors" },
  { name: "crack", label: "WPA Cracking", desc: "Dictionary attack cracked handshake", icon: "terminal" },
  { name: "crawl", label: "AP Scan", desc: "Scan access points in range", icon: "search" },
  { name: "client-hunt", label: "Client Hunt", desc: "Enumerate clients on target AP", icon: "users" },
];
---

<Layout title="Dashboard">
  <Navbar slot="nav" active="/" />

  <!-- Header -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 animate-slide-down">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight bg-card bg-clip-text text-transparent">
        HackIT Wireless
      </h1>
      <p class="text-sm text-muted-foreground mt-1.5 flex items-center gap-2">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-glow"></span>
        Enterprise Wireless Security Platform &mdash; 8 engines &bull; 15 attack modules
      </p>
    </div>
    <Button variant="outline" size="sm" onclick="window.clearTerminal?.()" class="group">
      <i data-lucide="trash-2" class="w-3.5 h-3.5 group-hover:text-red-500 transition-colors"></i>
      Clear Log
    </Button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
    <Card variant="gradient" class="group hover:border-primary/20 hover:shadow-md hover:-translate-y-0.5">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="absolute top-0 left-0 w-full h-0.5 bg-card
      <div class="relative z-10 p-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs text-muted-foreground uppercase tracking-wider font-semibold flex items-center gap-2">
            <i data-lucide="smartphone" class="w-3.5 h-3.5 text-primary"></i>
            Adapters
          </span>
          <span class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center">
            <i data-lucide="activity" class="w-4 h-4 text-primary"></i>
          </span>
        </div>
        <div class="text-4xl font-bold text-foreground font-mono tracking-tight" id="stat-adapters">
          <span class="skeleton inline-block w-14 h-9 align-middle rounded-md"></span>
        </div>
        <p class="text-[11px] text-muted-foreground/60 mt-1.5">detected wireless interfaces</p>
      </div>
    </Card>

    <Card variant="gradient" class="group hover:border-emerald-500/20 hover:shadow-md hover:-translate-y-0.5">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="absolute top-0 left-0 w-full h-0.5 bg-card
      <div class="relative z-10 p-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs text-muted-foreground uppercase tracking-wider font-semibold flex items-center gap-2">
            <i data-lucide="layout-dashboard" class="w-3.5 h-3.5 text-emerald-500"></i>
            Monitor
          </span>
          <span class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
            <i data-lucide="pencil" class="w-4 h-4 text-emerald-500"></i>
          </span>
        </div>
        <div class="text-4xl font-bold text-emerald-500 font-mono tracking-tight" id="stat-monitor">
          <span class="skeleton inline-block w-14 h-9 align-middle rounded-md"></span>
        </div>
        <p class="text-[11px] text-muted-foreground/60 mt-1.5">interfaces in monitor mode</p>
      </div>
    </Card>

    <Card variant="gradient" class="group hover:border-violet-500/20 hover:shadow-md hover:-translate-y-0.5">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="absolute top-0 left-0 w-full h-0.5 bg-card
      <div class="relative z-10 p-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs text-muted-foreground uppercase tracking-wider font-semibold flex items-center gap-2">
            <i data-lucide="package" class="w-3.5 h-3.5 text-violet-500"></i>
            Plugins
          </span>
          <span class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center">
            <i data-lucide="layers" class="w-4 h-4 text-violet-500"></i>
          </span>
        </div>
        <div class="text-4xl font-bold text-violet-500 font-mono tracking-tight" id="stat-plugins">
          <span class="skeleton inline-block w-14 h-9 align-middle rounded-md"></span>
        </div>
        <p class="text-[11px] text-muted-foreground/60 mt-1.5">Lua &amp; Ruby modules loaded</p>
      </div>
    </Card>
  </div>

  <!-- Quick Scan -->
  <Card variant="gradient" class="group hover:border-primary/20 mb-10">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/[0.02] via-transparent to-emerald-500/[0.02] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
    <div class="absolute top-0 left-0 w-full h-0.5 bg-card
    <div class="relative z-10 p-6">
      <div class="flex items-start sm:items-center justify-between gap-4 flex-col sm:flex-row">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary via-emerald-500 to-violet-500 flex items-center justify-center text-white shrink-0 shadow-lg shadow-md group-hover:scale-110 transition-transform duration-500">
            <i data-lucide="search" class="w-5 h-5"></i>
          </div>
          <div>
            <h2 class="text-lg font-bold text-foreground">Quick Wireless Scan</h2>
            <p class="text-xs text-muted-foreground mt-0.5">Leverage all 8 engines &mdash; Python, Rust, Go, C, C++, C#, Lua, Ruby</p>
          </div>
        </div>
        <button id="quick-scan-btn" onclick="runQuickScan()"
          class="group/btn relative px-6 py-2.5 rounded-xl bg-card text-white text-sm font-semibold transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2.5 shrink-0 overflow-hidden shadow-lg shadow-md hover:shadow-md">
          <span class="absolute inset-0 bg-card -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></span>
          <i data-lucide="search" class="w-4 h-4"></i>
          <span id="scan-btn-text">Scan Now</span>
        </button>
      </div>

      <!-- Loading state -->
      <div id="scan-loading" class="mt-6 hidden animate-slide-down">
        <div class="flex flex-col items-center py-8">
          <div class="relative w-16 h-16 mb-5">
            <div class="absolute inset-0 rounded-full border-2 border-primary/20 border-t-primary animate-spin"></div>
            <div class="absolute inset-2 rounded-full border-2 border-emerald-500/20 border-b-emerald-500 animate-spin-slow"></div>
            <div class="absolute inset-4 rounded-full border-2 border-violet-500/20 border-r-violet-500 animate-spin" style="animation-direction: reverse;"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <i data-lucide="search" class="w-4 h-4 text-primary"></i>
            </div>
          </div>
          <p class="text-sm text-muted-foreground mb-3 font-medium">Scanning with all engines</p>
          <div class="flex flex-wrap gap-2 justify-center max-w-md" id="scan-engine-names">
            <span class="px-2.5 py-1 rounded-lg bg-card border border-border text-[11px] text-muted-foreground animate-pulse-soft pulse-delay-0">Python</span>
          </div>
        </div>
      </div>

      <!-- Scan results -->
      <div id="scan-results" class="mt-6 hidden animate-slide-up">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs text-muted-foreground font-medium flex items-center gap-2">
            <i data-lucide="search" class="w-3.5 h-3.5 text-emerald-500"></i>
            Found <span id="scan-count" class="text-foreground font-bold text-sm">0</span> access points
          </span>
          <div class="flex gap-1.5" id="scan-engines"></div>
        </div>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-xs">
            <thead>
              <tr class="bg-muted/50 text-muted-foreground uppercase tracking-wider text-[11px]">
                <th class="px-4 py-3 text-left font-semibold">#</th>
                <th class="px-4 py-3 text-left font-semibold">SSID</th>
                <th class="px-4 py-3 text-left font-semibold">BSSID</th>
                <th class="px-4 py-3 text-left font-semibold">Ch</th>
                <th class="px-4 py-3 text-left font-semibold">Signal</th>
                <th class="px-4 py-3 text-left font-semibold">Security</th>
                <th class="px-4 py-3 text-left font-semibold">Source</th>
              </tr>
            </thead>
            <tbody id="scan-tbody"></tbody>
          </table>
        </div>
        <div id="scan-errors" class="mt-3 text-xs text-red-500 hidden bg-red-500/5 border border-red-500/20 rounded-lg px-4 py-2.5"></div>
      </div>

      <!-- Empty state -->
      <div id="scan-empty" class="mt-6 hidden animate-scale-in">
        <div class="flex flex-col items-center py-10">
          <div class="w-16 h-16 rounded-2xl bg-muted/50 flex items-center justify-center mb-4 border border-border">
            <i data-lucide="search" class="w-7 h-7 text-muted-foreground"></i>
          </div>
          <p class="text-sm text-muted-foreground font-medium">No access points found</p>
          <p class="text-xs text-muted-foreground/60 mt-1">Check your wireless interface or try again</p>
        </div>
      </div>

      <!-- Engine raw outputs -->
      <div id="scan-details" class="mt-4 hidden animate-slide-down">
        <button onclick="toggleEngineOutput()" class="group/dt text-xs text-muted-foreground hover:text-primary transition-colors flex items-center gap-1.5 px-2 py-1 rounded-lg hover:bg-primary/5">
          <i id="details-chevron" data-lucide="chevron-right" class="w-3 h-3 transition-transform duration-200"></i>
          Engine raw output
        </button>
        <div id="engine-outputs" class="mt-3 hidden space-y-2"></div>
      </div>
    </div>
  </Card>

  <!-- Attack grid -->
  <Card variant="gradient" class="flex items-center gap-3 mb-5 animate-fade-in p-4">
    <div class="w-8 h-8 rounded-lg bg-card flex items-center justify-center">
      <i data-lucide="zap" class="w-4 h-4 text-white"></i>
    </div>
    <h2 class="text-lg font-bold text-foreground">Attack Modules</h2>
    <span class="text-[11px] text-muted-foreground bg-muted/50 px-2.5 py-1 rounded-full border border-border">{attacks.length} payloads</span>
  </Card>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">
    {attacks.map(a => <AttackCard {...a} />)}
  </div>

  <!-- Terminal -->
  <div class="flex items-center gap-3 mb-5 animate-fade-in">
    <div class="w-8 h-8 rounded-lg bg-card flex items-center justify-center">
      <i data-lucide="terminal" class="w-4 h-4 text-white"></i>
    </div>
    <h2 class="text-lg font-bold text-foreground">Live Output</h2>
    <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground bg-muted/50 px-2.5 py-1 rounded-full border border-border">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-glow"></span>
      real-time
    </span>
  </div>
  <TerminalOutput id="main-terminal" height="350px" label="DASHBOARD" />
</Layout>

<script>
const ENGINE_COLORS = {
  'Python': 'bg-emerald-500/20 text-emerald-500 border-emerald-500/30',
  'Rust': 'bg-orange-500/20 text-orange-500 border-orange-500/30',
  'Go': 'bg-primary/20 text-primary border-primary/30',
  'C': 'bg-amber-400/20 text-amber-400 border-amber-400/30',
  'C++': 'bg-pink-500/20 text-pink-500 border-pink-500/30',
  'C#': 'bg-violet-500/20 text-violet-500 border-violet-500/30',
  'Lua': 'bg-primary/20 text-primary border-primary/30',
  'Ruby': 'bg-red-500/20 text-red-500 border-red-500/30',
};

const ENGINE_DOT_COLORS = {
  'Python': 'emerald-500',
  'Rust': 'orange-500',
  'Go': 'primary',
  'C': 'amber-400',
  'C++': 'pink-500',
  'C#': 'violet-500',
  'Lua': 'primary',
  'Ruby': 'red-500',
};

function getEngineColor(engine) {
  for (const [key, val] of Object.entries(ENGINE_COLORS)) {
    if (engine.includes(key)) return val;
  }
  return 'bg-emerald-500/20 text-emerald-500 border-emerald-500/30';
}

function getEngineDotColor(engine) {
  for (const [key, val] of Object.entries(ENGINE_DOT_COLORS)) {
    if (engine.includes(key)) return val;
  }
  return 'emerald-500';
}

function animateCounter(el, target, duration = 800) {
  const start = performance.now();
  const initial = parseInt(el.textContent) || 0;
  const frame = (now) => {
    const p = Math.min((now - start) / duration, 1);
    const eased = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.floor(initial + (target - initial) * eased);
    if (p < 1) requestAnimationFrame(frame);
  };
  requestAnimationFrame(frame);
}

async function loadStats() {
  try {
    const [adaptersRes, pluginsRes] = await Promise.all([
      fetch('/api/adapters'),
      fetch('/api/plugins')
    ]);
    const adapters = (await adaptersRes.json()).adapters || [];
    const plugins = (await pluginsRes.json());

    const adEl = document.getElementById('stat-adapters');
    const monEl = document.getElementById('stat-monitor');
    const plEl = document.getElementById('stat-plugins');

    const adCount = adapters.length;
    const monCount = adapters.filter(a => a.is_monitor).length;
    const plCount = (plugins.lua?.length || 0) + (plugins.ruby?.length || 0);

    if (adEl) {
      adEl.textContent = '0';
      requestAnimationFrame(() => animateCounter(adEl, adCount));
    }
    if (monEl) {
      monEl.textContent = '0';
      requestAnimationFrame(() => animateCounter(monEl, monCount));
    }
    if (plEl) {
      plEl.textContent = '0';
      requestAnimationFrame(() => animateCounter(plEl, plCount));
    }

    const names = adapters.map(a => `<span class="text-emerald-500 font-semibold">${a.name}</span>`).join(', ');
    if (names) window.appendTerminal?.('Adapters detected: ' + names);
  } catch { /* ignore */ }
}

async function runQuickScan() {
  const btn = document.getElementById('quick-scan-btn');
  const btnText = document.getElementById('scan-btn-text');
  const results = document.getElementById('scan-results');
  const loading = document.getElementById('scan-loading');
  const empty = document.getElementById('scan-empty');
  const errors = document.getElementById('scan-errors');
  const tbody = document.getElementById('scan-tbody');
  const count = document.getElementById('scan-count');
  const engines = document.getElementById('scan-engines');
  const details = document.getElementById('scan-details');
  const engineOutputs = document.getElementById('engine-outputs');
  const engineNames = document.getElementById('scan-engine-names');

  btn.disabled = true;
  btnText.textContent = 'Scanning...';
  results.classList.add('hidden');
  empty.classList.add('hidden');
  errors.classList.add('hidden');
  details.classList.add('hidden');
  loading.classList.remove('hidden');

  if (engineNames) {
    const allEngines = ['Python', 'Rust', 'Go', 'C', 'C++', 'C#', 'Lua', 'Ruby'];
    engineNames.innerHTML = allEngines.map((e, i) =>
      `<span class="px-2.5 py-1 rounded-lg bg-card border border-border text-[11px] text-muted-foreground animate-pulse-soft" style="animation-delay:${i * 0.12}s">${e}</span>`
    ).join('');
  }

  try {
    const r = await fetch('/api/quick-scan', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({iface: 'wlan0'})
    });
    const data = await r.json();

    loading.classList.add('hidden');

    if (data.errors && data.errors.length) {
      errors.textContent = 'Warnings: ' + data.errors.join('; ');
      errors.classList.remove('hidden');
    }

    engines.innerHTML = (data.engines || []).map(s => {
      const color = getEngineColor(s);
      return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-semibold border ${color}">
        <span class="w-1.5 h-1.5 rounded-full bg-${getEngineDotColor(s)}"></span>
        ${s}
      </span>`;
    }).join('');

    if (data.engine_outputs) {
      let html = '';
      for (const [eng, out] of Object.entries(data.engine_outputs)) {
        if (out) {
          const color = eng === 'Rust' ? 'border-orange-500/20' : 'border-primary/20';
          html += `<div class="rounded-lg bg-muted/30 border ${color} p-3">
            <div class="text-[10px] text-muted-foreground font-semibold mb-1.5 uppercase tracking-wider flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-${getEngineDotColor(eng)}"></span>
              ${eng} output
            </div>
            <pre class="text-[11px] text-muted-foreground/80 font-mono leading-relaxed max-h-28 overflow-y-auto">${out}</pre>
          </div>`;
        }
      }
      if (html) {
        engineOutputs.innerHTML = html;
        details.classList.remove('hidden');
      }
    }

    if (data.aps && data.aps.length) {
      count.textContent = data.count;
      tbody.innerHTML = data.aps.map((ap, i) => {
        const sigValue = ap.signal_rust != null ? ap.signal_rust : ap.signal;
        const isDbm = ap.signal_rust != null;
        const signalColor = sigValue >= -60 ? 'text-emerald-500' :
                            sigValue >= -70 ? 'text-amber-400' :
                            sigValue >= -80 ? 'text-orange-500' : 'text-red-500';
        const signalBars = sigValue >= -50 ? 4 : sigValue >= -60 ? 3 : sigValue >= -70 ? 2 : sigValue >= -80 ? 1 : 0;
        const barsHtml = '<span class="inline-flex items-end gap-[2px] mr-2 h-3">' +
          [1,2,3,4].map((_, j) => {
            const fill = j < signalBars;
            const barColor = signalBars === 4 ? 'bg-emerald-500' :
                             signalBars === 3 ? 'bg-amber-400' :
                             signalBars === 2 ? 'bg-orange-500' : 'bg-red-500';
            return `<span class="w-[3px] rounded-sm transition-all ${fill ? barColor : 'bg-border'}" style="height:${4 + j * 3}px"></span>`;
          }).join('') + '</span>';
        const sourceBadge = (() => {
          const s = ap.source || '';
          const color = getEngineColor(s);
          return `<span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-medium border ${color}">${s}</span>`;
        })();
        const signalStr = sigValue + (isDbm ? ' dBm' : '%');
        const rowClass = i % 2 === 0 ? 'bg-transparent' : 'bg-muted/20';
        return `<tr class="${rowClass} border-b border-border/40 hover:bg-primary/[0.03] transition-colors">
          <td class="px-4 py-3 text-muted-foreground">${i+1}</td>
          <td class="px-4 py-3 text-foreground font-medium">${ap.ssid || '<span class="text-muted-foreground/40 italic">hidden</span>'}</td>
          <td class="px-4 py-3 font-mono text-muted-foreground">${ap.bssid.replace(/\\\\:/g, ':')}</td>
          <td class="px-4 py-3 text-muted-foreground">${ap.channel}</td>
          <td class="px-4 py-3"><div class="flex items-center gap-1 ${signalColor} font-mono">${barsHtml}<span>${signalStr}</span></div></td>
          <td class="px-4 py-3 text-muted-foreground">${ap.security || '?'}</td>
          <td class="px-4 py-3">${sourceBadge}</td>
        </tr>`;
      }).join('');
      results.classList.remove('hidden');
      HackitUI.success(`${data.count} APs Found`);
    } else {
      empty.classList.remove('hidden');
      HackitUI.info('No APs', 'Check your interface');
    }
  } catch (e) {
    loading.classList.add('hidden');
    const msg = e.message || 'Unknown error';
    errors.textContent = 'Scan failed: ' + msg;
    errors.classList.remove('hidden');
    HackitUI.error('Scan Failed', msg);
  }

  btn.disabled = false;
  btnText.textContent = 'Scan Now';
}

function toggleEngineOutput() {
  const el = document.getElementById('engine-outputs');
  const chevron = document.getElementById('details-chevron');
  if (el.classList.contains('hidden')) {
    el.classList.remove('hidden');
    chevron.style.transform = 'rotate(90deg)';
  } else {
    el.classList.add('hidden');
    chevron.style.transform = '';
  }
}

loadStats();
</script>
