---
import "../styles/global.css";
interface Props { title?: string; }
const { title = "HackIT Wireless" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — HackIT Wireless</title>
    <meta name="description" content="Enterprise-grade wireless security auditing platform. Multi-engine WiFi penetration testing with C, C++, C#, Rust, Go, Python, Lua, and Ruby." />
    <meta name="author" content="Hanif Abdurrohim" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2300d4ff'/%3E%3Cstop offset='100%25' stop-color='%2300ff41'/%3E%3C/linearGradient%3E%3C/defs%3E%3Ccircle cx='16' cy='16' r='15' fill='%23060610' stroke='url(%23g)' stroke-width='2'/%3E%3Ctext x='16' y='21' text-anchor='middle' fill='%2300ff41' font-size='16' font-weight='bold' font-family='monospace'%3EH%3C/text%3E%3C/svg%3E" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
    if (typeof Swal !== 'undefined') {
      const themeOpts = {
        background: 'rgba(10,10,26,0.95)', color: '#f8fafc',
        confirmButtonColor: '#00d4ff', cancelButtonColor: '#1e293b', denyButtonColor: '#ff0040',
        backdrop: 'rgba(0,0,0,0.7)',
        customClass: {
          popup: 'rounded-2xl border border-border/50 shadow-lg backdrop-blur-xl',
          title: 'text-lg font-bold text-white',
          htmlContainer: 'text-sm text-muted-foreground',
          confirmButton: 'px-5 py-2.5 rounded-xl !bg-primary !text-primary-foreground text-sm font-semibold border-0 cursor-pointer transition-all duration-300',
          cancelButton: 'px-5 py-2.5 rounded-xl !bg-card !border !border-border !text-muted-foreground text-sm font-medium cursor-pointer hover:!text-foreground transition-all duration-300',
          denyButton: 'px-5 py-2.5 rounded-xl !bg-destructive !text-destructive-foreground text-sm font-semibold border-0 cursor-pointer transition-all duration-300',
          input: 'w-full px-3.5 py-2.5 rounded-xl bg-card border border-border text-sm text-foreground placeholder-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all !mx-0 !my-2',
          actions: 'gap-3',
          timerProgressBar: '!bg-primary',
        },
        showClass: { popup: 'animate-slide-up-fade', backdrop: 'animate-fade-in' },
        hideClass: { popup: 'opacity-0 transition-all duration-200' },
      };
      Swal.mixin(themeOpts);
      window.SwalToast = Swal.mixin({ ...themeOpts, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, timerProgressBar: true });
      window.HackitUI = {
        toast: (o) => (window.SwalToast || Swal).fire({ icon: o.icon||'success', title: o.title||'', text: o.text||'', ...o }),
        confirm: async (o) => Swal.fire({ icon: o.icon||'warning', title: o.title||'Are you sure?', text: o.text||'', showCancelButton: true, confirmButtonText: o.confirmText||'Yes, proceed', cancelButtonText: o.cancelText||'Cancel', reverseButtons: true, focusCancel: true, ...o }),
        loading: (t) => Swal.fire({ title: t||'Processing...', allowOutsideClick: false, allowEscapeKey: false, showConfirmButton: false, didOpen: () => Swal.showLoading() }),
        close: () => Swal.close(),
        input: async (o) => Swal.fire({ title: o.title||'Input', input: o.input||'text', inputPlaceholder: o.placeholder||'', inputValue: o.value||'', showCancelButton: true, confirmButtonText: o.confirmText||'OK', cancelButtonText: 'Cancel', reverseButtons: true, inputValidator: o.validator||null, ...o }),
        error: (t, s) => (window.SwalToast||Swal).fire({ icon: 'error', title: t, text: s||'' }),
        success: (t, s) => (window.SwalToast||Swal).fire({ icon: 'success', title: t, text: s||'' }),
        info: (t, s) => (window.SwalToast||Swal).fire({ icon: 'info', title: t, text: s||'' }),
      };
    }
    </script>
    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
  </head>
  <body class="flex flex-col min-h-screen bg-background text-foreground">
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot name="nav" />
      <main class="flex-1 px-6 py-8 max-w-7xl mx-auto w-full animate-fade-in">
        <slot />
      </main>

      <div id="cookie-banner" role="alert" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-3xl hidden">
        <div class="rounded-2xl border border-border/40 p-5 bg-card/90 backdrop-blur-xl shadow-lg">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center shrink-0 text-primary-foreground font-bold text-lg">!</div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-foreground/80 leading-relaxed">
                <span class="text-primary font-semibold">Hi, I'm Hanif Abdurrohim</span>
                — a security researcher and penetration testing enthusiast.
                This interface is intended for <span class="text-muted-foreground font-medium">authorized security testing only</span>.
                Unauthorized use against networks you do not own or have explicit permission to test is
                <span class="text-destructive font-medium">illegal</span> and violates applicable laws.
                By using this tool you agree to take full responsibility for your actions.
              </p>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-muted-foreground">
                <span>&copy; 2024-2026 Hanif Abdurrohim</span>
                <a href="https://haniipp.space" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">haniipp.space</a>
                <span>Built with Astro, FastAPI, Go, Rust, C/C++, Python</span>
              </div>
            </div>
            <button onclick="dismissCookie()" class="shrink-0 px-5 py-2.5 rounded-xl text-sm font-semibold bg-primary text-primary-foreground hover:opacity-90 transition-all duration-300">
              I Understand
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
    (function() {
      const key = 'hackit_cookie_consent';
      if (localStorage.getItem(key)) return;
      const banner = document.getElementById('cookie-banner');
      if (banner) banner.classList.remove('hidden');
      window.dismissCookie = function() {
        localStorage.setItem(key, '1');
        if (banner) {
          banner.style.transition = 'all 0.4s ease-out';
          banner.style.transform = 'translateY(100%)';
          banner.style.opacity = '0';
          setTimeout(() => banner.remove(), 500);
        }
      };
    })();
    </script>
  </body>
</html>
