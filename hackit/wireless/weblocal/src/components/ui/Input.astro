---
export interface Props {
  label?: string;
  error?: string;
  class?: string;
  [key: string]: any;
}

const { label, error, class: className = '', ...rest } = Astro.props;
const id = rest.id || rest.name;
---

<div class="space-y-1.5 {className}">
  {label && <label for={id} class="text-xs text-muted-foreground font-medium block">{label}</label>}
  <input {id} class="w-full px-3.5 py-2.5 rounded-xl bg-card border border-border text-sm text-foreground placeholder-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed" {...rest} />
  {error && <p class="text-xs text-destructive">{error}</p>}
</div>
