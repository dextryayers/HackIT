---
export interface Props {
  variant?: 'default' | 'gradient' | 'glow';
  class?: string;
  [key: string]: any;
}

const { variant = 'default', class: className = '', ...rest } = Astro.props;

const variantClasses = {
  default: 'bg-card border border-border',
  gradient: 'bg-card border border-border/50 bg-gradient-to-br from-card via-card to-primary/5',
  glow: 'bg-card border border-primary/20 shadow-md',
};
---

<div class="relative overflow-hidden rounded-2xl transition-all duration-300 {variantClasses[variant]} {className}" {...rest}>
  <slot />
</div>
