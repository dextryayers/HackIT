---
import Card from "./ui/Card.astro";

const { name, label, desc, icon } = Astro.props;
---

<a href={"/attacks/" + name}
  class="group relative block transition-all duration-300 hover:-translate-y-1 hover:shadow-md active:scale-[0.98]">
  <Card class="hover:border-primary/30">
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 rounded-xl bg-card border border-border/30 flex items-center justify-center shrink-0 text-primary group-hover:text-primary transition-colors duration-300">
        <i data-lucide={icon || "help-circle"} class="w-5 h-5"></i>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 rounded-full bg-primary/60 group-hover:bg-primary transition-colors duration-300"></span>
          <h3 class="text-sm font-semibold text-card-foreground group-hover:text-primary transition-colors duration-300">{label}</h3>
        </div>
        <p class="text-xs text-muted-foreground leading-relaxed line-clamp-2">{desc}</p>
      </div>
    </div>

    <div class="mt-4 flex justify-end opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
      <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg bg-primary text-primary-foreground text-xs font-semibold">
        <i data-lucide="play" class="w-3 h-3"></i>
        Launch
      </span>
    </div>
  </Card>
</a>
